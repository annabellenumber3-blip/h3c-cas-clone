##############################################################################
#    Func Name: check_mutual_exclusive_params
# Date Created: 2018-03-14
#       Author: 
#  Description: check all params should not be same with each other
#        usage: $0
#       Output: None
#       Return: 0
#      Caution: max params is 9-1=8, the last param is error msg
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
check_mutual_exclusive_params()
{
    local error_msg
    local params_num=`expr $# - 1` # last param is error_msg

    eval error_msg=\${$#}

    declare -A temp_arr
    for i in `seq $params_num`; do
        param=${!i}
        if [ "X${temp_arr[$param]}" = "X" ]; then
            temp_arr[$param]=1
        else
            cvm_printlog "PRINT-CMD-CONSOLE" $error_msg
            unset temp_arr
            exit 1
        fi
    done

    unset temp_arr
}

##############################################################################
# Name: check_ms_env
# Date Created: 2018-03-14
#       Author:
#  Description: check if env of ms is ok: 1. if soft link exists
#        usage: $0 $__peer_ip
#       Output:
#       Return:
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
check_ms_env()
{
    local __peer_ip=$1

    if [ "X$__peer_ip" = "X" ]; then
        cvm_printlog "PRINT-CMD-CONSOLE" $shell_name "ERROR: peer ip is not inputed."
        return 1
    fi

    # check if soft link exists
    if [ ! -h /root/.ssh/hosts ]; then
        cvm_printlog "PRINT-CMD-CONSOLE-FORCE" $shell_name "ERROR: no soft link of /root/.ssh/hosts."
        return 1
    fi

    if [ ! -h /etc/cvm ]; then
        cvm_printlog "PRINT-CMD-CONSOLE-FORCE" $shell_name "ERROR: no soft link of /etc/cvm."
        return 1
    fi

    $ssh $__peer_ip 'sudo test -h /root/.ssh/hosts'
    if [ $? != 0 ]; then
        cvm_printlog "PRINT-CMD-CONSOLE-FORCE" $shell_name "ERROR: In $__peer_ip, no soft link of /root/.ssh/hosts."
        return 1
    fi

    $ssh $__peer_ip 'sudo test -h /etc/cvm'
    if [ $? != 0 ]; then
        cvm_printlog "PRINT-CMD-CONSOLE-FORCE" $shell_name "ERROR: In $__peer_ip, no soft link of /etc/cvm."
        return 1
    fi

    # check non-root user
    if [ "X${SSH_USER}" != "Xroot" ]; then
        # check if soft link exists
        if [ ! -h /home/${SSH_USER}/.ssh/hosts ]; then
            cvm_printlog "PRINT-CMD-CONSOLE-FORCE" $shell_name "ERROR: no soft link of /home/${SSH_USER}/.ssh/hosts."
            return 1
        fi

        $ssh $__peer_ip "sudo test -h /home/${SSH_USER}/.ssh/hosts"
        if [ $? != 0 ]; then
            cvm_printlog "PRINT-CMD-CONSOLE-FORCE" $shell_name "ERROR: In $__peer_ip, no soft link of /home/${SSH_USER}/.ssh/hosts."
            return 1
        fi

    fi

    return 0
}

##########################################################################
#    Func Name: get_local_ip
# Date Created: 2018-03-14
#       Author: 
#  Description: get local ip on vswitch0
#        usage: $0
#       Output: None
#       Return: 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
#  2023-03-15  s2533            get local ip on vswitch0 or vswitch0.vlanid
##############################################################################
###############################################################################
get_local_ip()
{
    local local_ip=""
    if [ -f /etc/drbd.d/r0.res ] && [ -f /etc/cmsd/cmsd.xml ]; then
        local_ip=$(grep "<self .*role=\"[12]\"" /etc/cmsd/cmsd.xml | /bin/grep -oP -m1 '(?<= ip=")[0-9.a-z:]+')
    else
        # check if ipv4 addr exists
        local_ip=`python /opt/bin/netcfgtool.pyc get --name=vswitch0 | grep ipv4 | awk -F "[=,/,']" '{print $3}'`
        # check if ipv6 addr exists
        if [ "X$local_ip" = "X" ]; then
          local_ip=`python /opt/bin/netcfgtool.pyc get --name=vswitch0 | grep ipv6 | awk -F "[=,/,']" '{print $3}'`
        fi
    fi

    echo $local_ip
}

##########################################################################
#    Func Name: format_ip_addr
# Date Created: 2023-08-17
#       Author: luofangli
#  Description: format ip addr
#        usage: $0
#       Output: None
#       Return: 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
#  2023-08-17  l13214            format ip addr
##############################################################################
###############################################################################
format_ip_addr()
{
    local ip_addr=$1
    if [ "X$ip_addr" != "X" ]; then
        python -c "import IPy; print (IPy.IP('$ip_addr').strCompressed())"
    fi
}
##############################################################################
#    Func Name: cvm_printlog
# Date Created: 2013-08-13
#       Author: gaoliang
#  Description: print log
#        usage: $0 $1 $2 $3
#               $1 : whether print log to console; PRINT-CMD-CONSOLE: print log to console .must
#               $2 : the caller's name, usually, it is the shell name; must
#               $3 : the message string; must
#       Output: None
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
cvm_printlog() {
    is_print_console=$1
    shell_name=$2
    shift 2

    #make up the full message
    HOSTNAME=$(hostname)
    DATE=$(date "+%Y-%m-%d %H:%M:%S")
    LOG_MSG="$DATE [${HOSTNAME}](${shell_name}):"PID=$$" :$*"

    #buildup the log file name
    CVM_LOGFILE="/var/log/cvm_master_slave.log"

    echo -e "${LOG_MSG}" >> ${CVM_LOGFILE}
    
    if [ "X$is_print_console" = "XPRINT-CMD-CONSOLE-FORCE" ]; then
        echo -e $*
    fi

: '
    if [ "X$is_print_console" = "XPRINT-CMD-CONSOLE" ]; then
        echo -e $*
    fi
'
}

##############################################################################
#    Func Name: do_cmd_and_exit_on_error
# Date Created: 2018-03-14
#       Author: d14404
#  Description: excute cmd and exit if error happens
#        usage: $0 cmd error_msg
#       Output: None
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
do_cmd_and_exit_on_error()
{
    local cmd
    local cmd_out
    local params_num=`expr $# - 1`

    eval error_msg=\${$#}

    for i in `seq $params_num`; do
        cmd="$cmd ${!i}"
    done

    cmd_out=$(eval "$cmd" 2>&1)

    if [ $? -ne 0 ]; then
        cvm_printlog "PRINT-CMD-CONSOLE" $error_msg
        exit 1
    fi

    if [ "X$cmd_out" != "X" ]; then
        echo $cmd_out
    fi
}

##############################################################################
#    Func Name: mount_vms_to_partition
# Date Created: 2018-03-14
#       Author: d14404
#  Description: mount /vms to specified partition, exit if no
#        usage: $0 partiton peer_ip
#       Output: None
#       Return: 1 0
#      Caution: this requires ssh no need to input password
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
mount_vms_to_partition()
{
    local partition=$1
    local peer_ip=$2

    mkfs -t ext4 $partition 1>>$CVM_LOG 2>&1
    mount $partition /vms
    /opt/bin/ms_add_vms_to_fstab.sh $partition
    cvm_printlog "PRINT-CMD-CONSOLE" $shell_name "success to mount vms to $partition and add vms to fstab."
    if [ "X$peer_ip" != "X" ]; then
        $ssh $peer_ip sudo mkfs -t ext4 $partition 1>>$CVM_LOG 2>&1
        $ssh $peer_ip sudo mount $partition /vms
        $ssh $peer_ip sudo /opt/bin/ms_add_vms_to_fstab.sh $partition
    fi
}

##############################################################################
#    Func Name: format_err_string
# Date Created: 2018-03-14
#       Author: d14404
#  Description: format err string
#        usage: $0 err_string params
#       Output: None
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
format_err_string()
{
    local err_str=$1
    shift 1

    err_str=`printf "$err_str" $@`
    echo $err_str
}
