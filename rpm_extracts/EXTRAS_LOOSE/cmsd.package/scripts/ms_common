#############################################################################
#    Func Name: adjust_tools
# Date Created: 2018-03-14
#       Author: d14404
#  Description: set tools according ipv4/ipv6
#        usage: $0 $ip
#       Output: None
#       Return: 
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
adjust_tools()
{
    local ip=$1

    grep -q ":" <<<$ip
    if [ $? -eq 0 ]; then
        ping="ping6"
        ssh="$ssh -6"
        REMOTE_CMD="/opt/bin/ms_remote_command.exp -6"
        REMOTE_INFO_CMD="/opt/bin/ms_peerinfo_checking.exp -6"
        REMOTE_GEN_SSHKEY="/opt/bin/ms_remote_gen_sshkey.exp -6"
        INET_PATTERN="inet6[[:space:]]"
        netmask_len=128
    else
        ping="ping"
        ssh="$ssh -4"
        REMOTE_CMD="/opt/bin/ms_remote_command.exp -4"
        REMOTE_INFO_CMD="/opt/bin/ms_peerinfo_checking.exp -4"
        REMOTE_GEN_SSHKEY="/opt/bin/ms_remote_gen_sshkey.exp -4"
        INET_PATTERN="inet[[:space:]]"
        netmask_len=32
    fi

    SSH_USER=`get_user_name`
    # if we are doning ms_recovery.sh, should use root
    if [ -f "$CVM_RECOVERY_FLAG" ]; then
        ps -ef | grep -q [m]s_recovery.sh
        if [ $? -eq 0 ]; then
            SSH_USER="root"
        fi
    fi


    ssh="$ssh -l ${SSH_USER}"
}
##############################################################################
#    Func Name: ms_check_by_id
# Date Created: 2021-04-01
#       Author: l13214
#  Description: check by-id from drbd res
#        usage: $0
#       Output: None
#       Return: 1 0
#      Caution: 
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
ms_check_by_id()
{
    grep -Eq "^[[:space:]]*disk[[:space:]].*/dev/disk/by-id/" /etc/drbd.d/r0.res
    if [ $? -eq 0 ]; then
        echo 1
    else
        echo 0
    fi
}
##############################################################################
#    Func Name: cvm_get_drbd_disk
# Date Created: 2021-04-01
#       Author: l13214
#  Description: get local sync disk from drbd res
#        usage: $0
#       Output: None
#       Return: local sync disk
#      Caution: 
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
cvm_get_drbd_disk()
{
    local master_ip=$1
    local res=$2

    diskpathdev=/dev/
    local ip_line=$(sed -n "/$master_ip/=" $res)
    local disk_line=$(expr $ip_line-1|bc)
    local disk_used_drbd_id=$(sed -n "${disk_line}p" $res 2>/dev/null | grep "[[:space:]]*disk[[:space:]]" | awk '{print $2}' | tr -d '";')
    local disk_used=$(readlink $disk_used_drbd_id |awk -F '/' '{print $3}')
    local drbd_disk=$diskpathdev$disk_used
    echo $drbd_disk
}
##############################################################################
#    Func Name: cvm_get_peer_drbd_disk
# Date Created: 2021-04-01
#       Author: l13214
#  Description: get peer sync disk from drbd res
#        usage: $0
#       Output: None
#       Return: peer sync disk
#      Caution: 
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
cvm_get_peer_drbd_disk()
{
    local peer_ip=$1
    local res=$2

    diskpathdev=/dev/
    local ip_line=$(sed -n "/$peer_ip/=" $res)
    local disk_line=$(expr $ip_line-1|bc)
    local disk_used_drbd_id=$(sed -n "${disk_line}p" $res 2>/dev/null | grep "[[:space:]]*disk[[:space:]]" | awk '{print $2}' | tr -d '";')
    local disk_used=$($ssh $peer_ip sudo readlink $disk_used_drbd_id |awk -F '/' '{print $3}')
    local peer_drbd_disk=$diskpathdev$disk_used
    echo $peer_drbd_disk
}

#############################################################################
#    Func Name: sudo_scp
# Date Created: 2018-03-14
#       Author: d14404
#  Description: copy to remote using sudo
#        usage: $0 $ip
#       Output: None
#       Return:
#      Caution: must be called after adjust_tools
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
sudo_scp()
{
    local local_file=$1
    local remote_ip=$2
    local remote_file=$3

    if [ "X${remote_file}" = "X" ]; then
        remote_file=${local_file}
    fi

    sudo cat "${local_file}" | $ssh ${remote_ip} "sudo tee ${remote_file}"
}

#############################################################################
#    Func Name: sudo_scp_dir
# Date Created: 2018-03-14
#       Author: d14404
#  Description: copy to remote using sudo
#        usage: $0 $ip
#       Output: None
#       Return:
#      Caution: must be called after adjust_tools
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
sudo_scp_dir()
{
    local local_dir=$1
    local remote_ip=$2
    local remote_dir=$3

    if [ "X${remote_dir}" = "X" ]; then
        remote_dir=${local_dir}
    fi

    sudo tar -C "${local_dir}" -c . -O | $ssh ${remote_ip} "sudo tar -C ${remote_dir} -x"
}
