cvm_get_ctl_ip()
{
    #get controller ip
    ctl_ip=$(grep "<host .*role=\"[3]\".*type=\"1\"" /etc/cmsd/cmsd.xml 2>/dev/null | /bin/grep -m 1 -oP '(?<=ip=")[0-9.a-z:]+')
    echo $ctl_ip
}
