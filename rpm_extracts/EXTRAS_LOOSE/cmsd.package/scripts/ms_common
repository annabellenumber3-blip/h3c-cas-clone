    local netmask

    if [ $# -eq 1 ]; then
        error_msg=$1
    else
        netmask=$1
        error_msg=$2
    fi 

    error_msg=$(format_err_string "$error_msg" "$netmask")

    if [ "X$netmask" = "X" ] || ! check_netmask $netmask ; then
