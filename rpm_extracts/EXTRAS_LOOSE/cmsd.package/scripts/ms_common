#    Func Name: ssh_keygen_check
# Date Created: 2018-03-14
#       Author: l13214
#  Description: timeout ssh check
#        usage: $0 $1
#       Output: None
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
ssh_keygen_check()
{
    timeout 15 bash <<EOF
$ssh $1 'sudo echo ok' &> /dev/null
exit 0
EOF
    if [ $? != 0 ]; then
        return 1
    fi
    return 0
}
