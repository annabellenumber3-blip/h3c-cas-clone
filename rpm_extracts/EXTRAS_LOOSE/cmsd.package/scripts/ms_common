##############################################################################
#    Func Name: get_user_name
# Date Created: 2020-12-23
#       Author: fengxiaojun
#  Description: get username
#        usage:
#       Output: Username
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
get_user_name()
{
    user_info_conf="/etc/cvk/user_info.conf"
    host_user_name="root"
    if [ -e "$user_info_conf" ]; then
        host_user_name=$(cat $user_info_conf | grep -w "^permit_user_ssh" | sed 's/[[:space:]]//g' | awk -F '=' '{print $2}')
    fi

    echo $host_user_name
}

##############################################################################
#    Func Name: get_nic_device_name
# Date Created: 2023-03-15
#       Author: s25313
#  Description: get nic device name
#        usage:
#       Output: nic device name(vswitch0 or vswitch0.vlanid)
#       Return:
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
get_nic_device_name()
{
    vlan_min=2
    vlan_max=4094
    nic_name=`/opt/bin/ovs_bridge.sh get vswitch0 --linux_bridge| awk '{print $3}'`
    if [ "X$nic_name" = "X" ];then
        nic_name="vswitch0"
        get_vlan_id=`/opt/bin/ovs_bridge.sh get vswitch0 --vlan | awk '{print $3}'`
        get_network_engine=`/opt/bin/ovs_bridge.sh get vswitch0 --network_engine | awk '{print $3}'`
        vlan_id=$(($get_vlan_id))
        if [[ "X$get_network_engine" = "Xlinux" && $vlan_id -ge 2 && $vlan_id -le 4094 ]]; then
            nic_name="$nic_name"."$vlan_id"
        fi
    else
        get_vlan_id=`/opt/bin/ovs_bridge.sh get vswitch0 --vlan | awk '{print $3}'`
        vlan_id=$(($get_vlan_id))
        if [[ $vlan_id -ge 2 && $vlan_id -le 4094 ]]; then
            nic_name="$nic_name"."$vlan_id"
        fi
    fi
    echo $nic_name
}

##############################################################################
#    Func Name: get_vbnic_device_name
# Date Created: 2024-07-13
#       Author: c16096
#  Description: get vb nic device name
#        usage:
#       Output: nic device name(vb or vb.vlanid)
#       Return:
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
get_vbnic_device_name()
{
    name=$1
    vlan_min=2
    vlan_max=4094
    nic_name=`/opt/bin/ovs_bridge.sh get $name --linux_bridge| awk '{print $3}'`
    get_vlan_id=`/opt/bin/ovs_bridge.sh get $name --vlan | awk '{print $3}'`
    vlan_id=$(($get_vlan_id))
    if [[ "X$nic_name" != "X" && $vlan_id -ge 2 && $vlan_id -le 4094 ]]; then
       nic_name="$nic_name"."$vlan_id"
    fi
    if [ "X$nic_name" = "X" ];then
       nic_name=$name
    fi
    echo $nic_name
}
##############################################################################
#    Func Name: sed_replace
# Date Created: 2013-05-17
#       Author: gaoliang
#  Description: replace str to another file
#        usage: $0 $1 
#               $1 : sed parameter1 .must
#               $2 : sed parameter2 .must
#               $3 : file .must
#       Output: None
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
sed_replace()
{
    if [ $# -lt 2 ] ; then
        echo "ERROR: Not enough arguments [$#] to input."
        exit 1
    fi 
    parm1=$1
    parm2=$2
    file=$3
    
    #random
    seconds=$(date +%N)
    BAK=".${seconds}.bak"
    
    #fix:202305221700 replace controller name
    controller_name=$(ms_info.sh controller hostname)
    if [ "X$parm1" == "X$controller_name" ]; then
        sed "6 s/$parm1/$parm2/g" ${file} > ${file}${BAK}
    else
        #modify other
        sed "s/$parm1/$parm2/g" ${file} > ${file}${BAK}
    fi
    
    if [ $? = 0 ]; then
        mv ${file}${BAK} $file
        rm -rf ${file}${BAK}
    else
        echo "sed s/$parm1/$parm2/g ${file} > ${file}${BAK} error."
        exit 1
    fi 
}
##############################################################################
#    Func Name: sed_delete
# Date Created: 2013-05-17
#       Author: gaoliang
#  Description: delete str to another file
#        usage: $0 $1 
#               $1 : sed parameter .must
#               $1 : file .must
#       Output: None
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
sed_delete()
{
    if [ $# -lt 2 ] ; then
        echo "ERROR: Not enough arguments [$#] to input."
        exit 1
    fi 
    parm=$1
    file=$2
        
    #random
    seconds=$(date +%N)
    BAK=".${seconds}.bak"
    
    #modify
    sed "/$parm/d" ${file} > ${file}${BAK}
    if [ $? = 0 ]; then
        mv ${file}${BAK} $file
        rm -rf ${file}${BAK}
    else
        echo "sed /$parm/d ${file} > ${file}${BAK} error."
        exit 1
    fi 
}
##############################################################################
#    Func Name: check_ping_ip
# Date Created: 2013-05-17
#       Author: gaoliang
#  Description: check ping ip
#        usage: $0 $1 
#               $1 : ip .must
#       Output: None
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
check_ping_ip()
{
    if [ $# -lt 1 ] ; then
        echo "ERROR: Not enough arguments [$#] to input."
        exit 1
    fi 
    ip=$1
    $ping -c 2 $ip 1>>$CVM_LOG 2>&1
    if [ $? != 0 ]; then
        echo "ERROR: host ip=$ip is not right, because this ip can not be pinged successfully"
        exit 1    
    fi
}
##############################################################################
#    Func Name: check_ip
# Date Created: 2013-05-17
#       Author: gaoliang
#  Description: check ip
#        usage: $0 $1 
#               $1 : ip .must
#       Output: None
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
check_ip()  
{  
    return 0

    if [ $# -lt 1 ] ; then
        echo "ERROR: Not enough arguments [$#] to input."
        exit 1
    fi
    ip=$1
    nic_name=`get_nic_device_name`
    brdip=$(ip addr show $nic_name |/bin/grep -m1 -oP '(?<=brd )[0-9.]+')
    rtn_ip=$(echo $ip | grep "^[0-9]\{1,3\}\.[0-9]\{1,3\}\.[0-9]\{1,3\}\.[0-9]\{1,3\}$")
    if [ "$ip" = "$brdip" ]; then
        return 1
    fi
    if [ "$rtn_ip" != "$ip" ]; then  
        return 1
    else  
        rtn=$(echo $ip | awk -F '.' '$1 < 255 && $1 > 0 && $2 < 256 && $2 >= 0 && $3 < 256 && $3 >= 0 && $4 < 256 && $4 >= 0 {print 1}')
        if [ "$rtn" != "1" ]; then
            return 1
        fi
    fi
    return 0
}
##############################################################################
#    Func Name: check_port
# Date Created: 2013-05-17
#       Author: 
#  Description: check ip
#        usage: $0 $1 
#               $1 : port .must
#       Output: None
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
check_port()  
{  
    port=$1
    rtn=$(echo $port | grep "^[1-9][0-9]\{3,4\}$")
    if [ "X$rtn" = "X" ]; then  
        return 1
    fi
    return 0
}
##############################################################################
#    Func Name: check_netmask
# Date Created: 2013-05-17
#       Author: 
#  Description: check ip
#        usage: $0 $1 
#               $1 : ip .must
#       Output: None
#       Return: 1 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
check_netmask()  
{  
    if [ $# -lt 1 ] ; then
        echo "ERROR: Not enough arguments [$#] to input."
        exit 1
    fi

    netmask=$1
    echo $netmask | grep -q "[^0-9]"
    if [ $? -eq 0 ]; then
        return 1
    fi
    if [[ $netmask -lt 0 || $netmask -gt $netmask_len ]]; then
        return 1
    fi

    return 0
}

##############################################################################
#    Func Name: check_ip_and_exit_on_error
# Date Created: 2018-03-14
#       Author: 
#  Description: check if inputed ip is in valid format, if not, exit the script
#        usage: $0
#       Output: None
#       Return: 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
check_ip_and_exit_on_error()
{
    local error_msg
    local ip

    if [ $# -eq 1 ]; then
        error_msg=$1
    else
        ip=$1
        error_msg=$2
    fi

    error_msg=$(format_err_string "$error_msg" "$ip")

    if [ "X$ip" = "X" ] || ! check_ip $ip ; then
        cvm_printlog "PRINT-CMD-CONSOLE" $error_msg
        exit 1
    fi
}

