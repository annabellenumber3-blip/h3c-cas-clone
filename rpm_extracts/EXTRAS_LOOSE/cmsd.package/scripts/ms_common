cvm_get_peer_ip()
{
    #get peer_ip
    peer_ip=$(grep "<host .*role=\"[12]\"" /etc/cmsd/cmsd.xml | /bin/grep -oP -m1 '(?<= ip=")[0-9.a-z:]+')
    echo $peer_ip
}
