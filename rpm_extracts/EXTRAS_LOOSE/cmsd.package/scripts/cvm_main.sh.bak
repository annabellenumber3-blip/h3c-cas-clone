#!/bin/bash
###############################################################################
#    Func Name: cvm_main.sh
# Date Created: 2013-05-08
#       Author: gaoliang/09136
#  Description: 'CVM active/standby backup' enable
#        usage: $0 $1 $2 $3 $4...
#               $1  : virtual ip(Ip of CVM service); must
#               $2  : test ip1; must, ping this ip to check whether this node's network is down
#               $3  : test ip2; must, ping this ip to check whether this node's network is down
#               $4  : this node hostname; must
#               $5  : this node ip; must
#               $6  : peer node hostname; must
#               $7  : peer node ip; must
#               $8  : peer node root password; must
#               $9  : drbd port1; must
#               $10 : drbd port2; must
#               $11 : multicast ip; must
#               $12 : multicast port; must
#               $13 : master node; default=$(hostname)
#               $14 : sync rate; default=100
#       Output: None
#       Return: 0  : success
#               1  : failed
#      Caution: 
#-----------------------------------------------------------------------------
#  Modification History 
#  DATE        NAME             DESCRIPTION
##############################################################################
###############################################################################
## Initialization shell
###############################################################################
HA_SHELL_SCRIPT_PATH=/opt/bin
echo "The system does not support stateful failover configuration in the CLI. Please configure stateful failover on the CVM platform."
exit 0
