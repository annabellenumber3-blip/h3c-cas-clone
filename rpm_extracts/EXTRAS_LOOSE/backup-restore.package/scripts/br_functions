############################################################################
#    File Name: make_up_backfile_info
# Date Created: 2013-02-19
#       Author: zhanglianxiang/09608
#  Description: make up backup file information of VM
#        Input: $1 backup file absolutely directory
#        input: $2 the compress specification
#       Output: error Code with some errors
#       Return: 0 if succeffully, other with errors
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
# 2014-9-9     guozhonghua      changed for optimization
##############################################################################
make_up_backfile_info()
{
    local MODULE_NAME=make_up_backfile_info
    local temp_path=$1
    local compressed=$2

    local current_path=`pwd`

    # cd backup file directory
    cd $temp_path
    if [ -e info ]; then
        rm -f info
    fi

    # compressed file
    echo $compressed > compressed

    #check
    local all_files=`ls * 2>/dev/null`
    local rtn=$?
    if [ "X$all_files" = "X" ] || [ $rtn -ne 0 ]; then
        br_printlog $MODULE_NAME err "can not find any files in dir $temp_path."
        cd $current_path
        return $BR_LIST_FILES
    fi

    br_printlog $MODULE_NAME debug "$temp_path: $all_files"

    # get size of files and make up information
    for tmp_gz in $all_files
    do
        # get name
        br_printlog $MODULE_NAME info " tmp_gz = $tmp_gz "
        echo -n "$tmp_gz" >> info

        # get size
        ls -l $tmp_gz | awk '{printf(" %s\n", $5)}' >> info
    done
    cd $current_path

    return $BR_SUCCESS
}

############################################################################
#    File Name: check_up_remote_disk_space
# Date Created: 2013-02-19
#       Author: zhanglianxiang/09608
#  Description: check up remote size of free disk space
#            $1 scp server ip or host name
#            $2 scp server port
#            $3 vm backup directory
#            $4 user'a password
#            $5 directory on the scp server
#       Return: 0 if succeffully, other with errors
#      Caution: only scp backup and only used in HA Cluster Manager
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
check_up_remote_disk_space()
{
    local MODULE_NAME=check_up_remote_disk_space
    local disk_info
    br_printlog $MODULE_NAME info "all params = $1 $2 $3 $4 @@@ $6"

    local user="$4"
    local passwd="$5"

    disk_info=`expect $BR_SHELL_PATH"/"get_disk_space_info.exp "$user"@"$1" $2 "$passwd" $6`
    rt=$?
    if [ $rt -ne 0 ]; then
        br_printlog $MODULE_NAME err "get remote disk space info faild with $rt"
        return $rt
    fi

    FREE_DISK_SPACE=`echo $disk_info | awk '{print $(NF - 2)}'`
    return_code=$?
    if [ $return_code -ne 0 ]; then
        br_printlog $MODULE_NAME err "parse disk info failed with $return_code"
        return $return_code
    fi

    cd $3
    sum=0
    if [ -e info ]; then
        while read line;
        do
            size=`echo $line | awk '{printf("%s\n",$2)}'`
            sum=`expr $sum + $size`
        done < info
    else
        images=`ls *.gz`
        for tmp_images in $images
        do
            gz=`ls -l $tmp_images | awk '{printf("%s ", $5)}'`
            sum=`expr $sum + $gz`
        done
        conf=`ls -l | grep *.conf | awk '{printf("%s ", $5)}'`
        sum=`expr $sum + $conf`
        xml=`ls -l | grep *.xml | awk '{printf("%s ", $5)}'`
        sum=`expr $sum + $xml`
    fi

    br_printlog $MODULE_NAME info "FREE_DISK_SPACE = $FREE_DISK_SPACE sum = $sum"
    if [ $FREE_DISK_SPACE -lt $sum ]; then
        br_printlog $MODULE_NAME err "check up remote disk space faild,NO ENOUGH SPACE!"
        return $BR_DISK_SPACE_NO_ENOUGH
    fi
    return $BR_SUCCESS
}

############################################################################
#    File Name: check_up_local_disk_space
# Date Created: 2013-02-19
#       Author: zhanglianxiang/09608
#  Description: check-up remote size of free disk space
#            $1 source directory
#            $2 destination directory
#       Return: 0 if succeffully, other with errors
#      Caution: only scp backup and only used in HA Cluster Manager
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
check_up_local_disk_space()
{
    local MODULE_NAME=check_up_local_disk_space

    # check destination directory free space of disk
    br_printlog $MODULE_NAME info "\$1 = $1,\$2 = $2"
    cd $2

    dest=`$DF_CMD -B1 "$2" | sed -n '2p' | awk '{printf("%s\n",$4)}'`
    if [ $? != 0 ]; then
        br_printlog $MODULE_NAME err "get destination directory free space of disk faild."
    fi

    # source directory
    cd $1
    sum=0
    if [ -e info ]; then
        while read line;
        do
            size=`echo $line | awk '{printf("%s\n",$2)}'`
            sum=`expr $sum + $size`
        done < info
    else
        list=`ls`
        for tmp_size in $list
        do
            size=`ls -l $tmp_size | awk '{printf("%s\n", $5)}'`
            sum=`expr $sum + $size`
        done
    fi

    br_printlog $MODULE_NAME info "\$sum = $sum,\$dest = $dest."
    if [ $dest -lt $sum ]; then
        br_printlog $MODULE_NAME err "check up destination disk space faild,NO ENOUGH SPACE!"
        return $BR_DISK_SPACE_NO_ENOUGH
    fi
    return $BR_SUCCESS
}

############################################################################
#    File Name: check_files_after_trans_for_ftp
# Date Created: 2013-02-19
#       Author: zhanglianxiang/09608
#  Description: check-up transfered files in ftp server
# Date Created: 2013-02-19
#        usage: check_files_after_trans_for_ftp 192.168.0.107 21 gzh 1q2w3e test dir
#            $1 vm backup file name (.gz)
#            $2 vm backup file name (.conf,.xml)
#       OUTPUT: NONE
#       RETURN: 0  : SUCCESS
#               1  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
check_files_after_trans_for_ftp()
{
    local MODULE_NAME=check_files_after_trans_for_ftp
    cd $3
    #check gz file size
    if [ ! -e backup_version.bak ]; then
        br_printlog $MODULE_NAME err "backup file info no exist!!!"
        return $BR_VM_NO_FIND_BAKUP_VERSION
    fi

    diff backup_version backup_version.bak >/dev/null
    if [ $? -ne 0 ]; then
        return $BR_VM_NO_FIND_BAKUP_VERSION
    fi

    return $BR_SUCCESS
}

############################################################################
#    File Name: delete_ftp_server_backup_file
# Date Created: 2013-02-19
#       Author: zhanglianxiang/09608
#  Description: delete ftp server backup file if backup faild
# Date Created: 2013-02-19
#        usage: delete_ftp_server_backup_file 192.168.0.107 21 gzh 1q2w3e test dir
#            $1 vm backup file name (.gz)
#            $2 vm backup file name (.conf,.xml)
#       OUTPUT: NONE
#       RETURN: 0  : SUCCESS
#               1  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
delete_ftp_server_backup_file()
{
    local MODULE_NAME=delete_ftp_server_backup_file

    result_values=`ftp -n -i $1 $2 <<EOF
    user $3 "$4"
    cd $5
    cd $6
    mdelete *
    cd ..
    rmdir "$6"
    bye
    EOF`

    return_code=$?
    if [ $return_code -ne 0 ]; then
        br_printlog $MODULE_NAME err "login FTP failed with return code $return_code"
        return $return_code
    fi

    # Parse the error information
    errorinfo=`echo $result_values | grep "Not connected"`
    if [ "X$errorinfo" != "X" ]; then
        return $BR_FTP_TRANSFER_1
    fi

    errorinfo=`echo $result_values | grep "Login failed"`
    if [ "X$errorinfo" != "X" ]; then
        return $BR_FTP_TRANSFER_2
    fi

    errorinfo=`echo $result_values | grep "550"`
    if [ "X$errorinfo" != "X" ]; then
        return $BR_FTP_TRANSFER_3
    fi
    return $BR_SUCCESS
}

############################################################################
#    File Name: check_up_backup_file_4_restore
# Date Created: 2013-02-19
#       Author: zhanglianxiang/09608
#  Description: check-up backup file for restore in scp or ftp after transfer backup files
# Date Created: 2013-02-19
#        usage: check_up_backup_file_4_restore restore dir
#            $1 dir for restore tmp directory
#       OUTPUT: NONE
#       RETURN: 0  : SUCCESS
#               1  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
check_up_backup_file_4_restore()
{
    local MODULE_NAME=check_up_backup_file_4_restore
    cd $1
    if [ ! -e info ]; then
        br_printlog $MODULE_NAME err "info file no exist in $1"
        return $BR_INFO_FILE_NO_EXIST
    fi

    tmp_files=`ls *`
    for files in $tmp_files
    do
        #read info
        size1=`cat info | grep "$files" | awk '{printf("%s\n",$2)}'`

        #read backup file information
        size2=`ls -l | grep "$files" | awk '{printf("%s\n",$5)}'`

        #compare
        if [ $size1 -ne $size2 ]; then
            br_printlog $MODULE_NAME err "$files is something wrong"
            return $BR_FTP_SERVER_NOT_RESP
        fi
    done

    return $BR_SUCCESS
}

##############################################################################
#    Func Name: make_info_4_old_version_ftp
# Date Created: 2013-03-13
#       Author: zhanglianxiang/09608
#  Description: make info file for old version backup vm when restoring vm in new version
#        usage: make_info_4_old_version $1 $2 $3 $4 $5 $6 info
#            $1 server ip or host name
#            $2 ftp server port
#            $3 user name
#            $4 user'a password
#            $5 directory on the ftp server
#            $6 the VM directory to be built
#       OUTPUT: NONE
#       RETURN: 0  : SUCCESS
#               1  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
make_info_4_old_version_ftp()
{
    # Module name for log
    local MODULE_NAME=make_info_4_old_version_ftp
    br_printlog $MODULE_NAME info "@ = $1 $2 $3 @@@ $5 $6"
    result_values=`ftp -n -i $1 $2 <<EOF
    user $3 "$4"
    cd $5
    binary
    cd $6
    #prompt
    dir . tmp_info
    bye
EOF`
    gz_list=`cat tmp_info | grep "gz"`
    for gz in $gz_list
    do
        echo $gz | awk '{printf("%s %s\n",$9,$5)}'>>info
    done

    conf_list=`cat tmp_info | grep "conf"`
    for conf in $conf_list
    do
        echo $conf | awk '{printf("%s %s\n",$9,$5)}'>>info
    done

    xml_list=`cat tmp_info | grep "xml"`
    for xml in $xml_list
    do
        echo $xml | awk '{printf("%s %s",$9,$5)}'>>info
    done
    rm -f tmp_info
    return $BR_SUCCESS
}

##############################################################################
#    Func Name: ftp_get_file
# Date Created: 2013-03-06
#       Author: zhanglianxiang/09608
#  Description: get files through ftp (info conf)
#        usage: ftp_get_file 192.168.0.107 21 gzh 1q2w3e test test1 info
#            $1 server ip or host name
#            $2 ftp server port
#            $3 user name
#            $4 user'a password
#            $5 directory on the ftp server
#            $6 the VM directory to be built
#            $7 file name
#       OUTPUT: NONE
#       RETURN: 0  : SUCCESS
#               1  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
ftp_get_file()
{
    # Module name for log
    local MODULE_NAME=ftp_get_file
    br_printlog $MODULE_NAME info "@ = $1 $2 $3 @@@ $5 $6"
    result_values=`ftp -n -i $1 $2 <<EOF
        user $3 "$4"
        cd $5
        binary
        cd $6
        #prompt
        mget $7
        bye
EOF`

    echo "FTP result values="$result_values
    return_code=$?
    if [ $return_code -ne 0 ]; then
        br_printlog $MODULE_NAME err "Execute FTP transfer get failed with return code $return_code"
        return $return_code
    fi

    errorinfo=`echo $result_values | grep "Not connected"`
    if [ "X$errorinfo" != "X" ]; then
        return $BR_FTP_TRANSFER_1
    fi

    errorinfo=`echo $result_values | grep "Login failed"`
    if [ "X$errorinfo" != "X" ]; then
        return $BR_FTP_TRANSFER_2
    fi

    errorinfo=`echo $result_values | grep "$5"`
    if [ "X$errorinfo" != "X" ]; then
        return $BR_FTP_TRANSFER_3
    fi

    errorinfo=`echo $result_values | grep "$6"`
    if [ "X$errorinfo" != "X" ]; then
        return $BR_FTP_TRANSFER_3
    fi

    dir=`pwd`
    br_printlog $MODULE_NAME info "FTP dir = $dir"
    #check_up_backup_file_4_restore $dir
    if [ ! -e $dir/info ]; then
        #make a new info file
        make_info_4_old_version_ftp $1 $2 $3 $4 $5 $6
        return_code=$?
        if [ $return_code != 0 ]; then
            br_printlog $MODULE_NAME err "FTP make new info file failed with $return_code"
            return $return_code
        fi
    fi

    return $BR_SUCCESS
}

##############################################################################
#    Func Name: version_for_backup
# Date Created: 2013-03-14
#       Author: zhanglianxiang/09608
#  Description: recode version for backup
#        usage: version_for_backup $1
#            $1 directory of backup file
#            $2 backup method. "cbt" or "convertsum"
#            $3 new backup
#            $4 backup disk
#       OUTPUT: NONE
#       RETURN: 0  : SUCCESS
#               1  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
version_for_backup()
{
    local MODULE_NAME=version_for_backup
    br_printlog $MODULE_NAME info "@ = $@"
    if [ ! -d $1 ]; then
        br_printlog $MODULE_NAME eer "$1 not a directory"
        return $BR_DIRECTORY_ERROR
    fi

    if [ -e /etc/cas_cvk-version ]; then
        cp /etc/cas_cvk-version $1/backup_version
    fi

    if [ $# -gt 1 ]; then
        local version_backup="backup_version $2"
        echo "$version_backup" >> $1/backup_version
    fi

    if [ $# -gt 2 ]; then
        local backup_disk=$3
        if [ $backup_disk == "0" ]; then
            local disk_backup_type=0
        else
            local disk_backup_type=1
        fi

        local disk_backup_value="disk_backup_type $disk_backup_type"
        echo "$disk_backup_value" >> $1/backup_version
    fi

    if [ $# -gt 3 ]; then
        local backup_method="backup_method $4"
        echo "$backup_method" >> $1/backup_version
    fi

    br_printlog $MODULE_NAME info "copy version file (and new backup) to $1"
    return $BR_SUCCESS

}

