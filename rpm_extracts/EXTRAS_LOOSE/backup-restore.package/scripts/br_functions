##############################################################################
# funcion   : get current datetime
##############################################################################
brdate() {
    date "+${__BR_DATEFMT}"
}

##############################################################################
# funcion   : get current month, eg. 201106
##############################################################################
brCurrentMonth() {
    date "+%Y%m"
}
 
##############################################################################
#    Func Name: br_printlog
# Date Created: 2011-07-21
#       Author: guozhonghua
#  Description: print log to a log file; if debug and we're connected to a tty,
#               then output to stderr,otherwise, to logfile.
#        usage: $0 $1 $2 $3
#               $1 : the caller's name, usually, it is the shell name; must
#               $2 : the log level, it must be one of {crit|err|warn|info|debug}; must
#               $3 : the message string; must
#       Output: None
#       Return: 0
#      Caution:
#-----------------------------------------------------------------------------
#  Modification History
#  DATE        NAME             DESCRIPTION
##############################################################################
br_printlog()
{
    # check the invalidity of the params.
    if [ $# -lt 3 ]; then
        br_printlog testshell err "Not enough arguments [$#] to ha_printlog."
        return 0
    fi

    #save the parameters
    __BR_LOG_FROM="$1"
    shift
    __BR_LOG_PRIO="$1"
    shift
    __BR_LOG_MSG="$*"

    #format the log/debug level.
    case "${__BR_LOG_PRIO}" in
          crit)     __BR_LOG_PRIO="CRIT";;
          err)      __BR_LOG_PRIO="ERROR";;
          warn)     __BR_LOG_PRIO="WARNING";;
          info)     __BR_LOG_PRIO="INFO";;
          debug)    __BR_LOG_PRIO="DEBUG";;
          *)        __BR_LOG_PRIO=`echo ${__BR_LOG_PRIO}| tr '[a-z]' '[A-Z]'`;;
    esac

    #make up the full message
    __BR_HOSTNAME=`hostname`
    __BR_LOG_MSG=`brdate`" ["${__BR_HOSTNAME}"]("${__BR_LOG_FROM}"): "${__BR_LOG_PRIO}":"${__BR_LOG_MSG}

    #buildup the log file name
    __BR_LOGFILE_DIR="/var/log/caslog/backup-restore/"
    if [ ! -d ${__BR_LOGFILE_DIR} ];then
        mkdir -p ${__BR_LOGFILE_DIR}
    fi
    __BR_LOGFILE="${__BR_LOGFILE_DIR}cas_br.log"
    #echo ${__BR_LOGFILE}

    # Write the log info into log files
    # modified by shichangkuo: no matter with "DEBUG", all print to logfile. 2013-03-05
    #if [ "${__BR_LOG_PRIO}" = "DEBUG" -a tty >/dev/null ]; then
    #    echo ${__BR_LOG_MSG}
    #else
        echo -e ${__BR_LOG_MSG} >> ${__BR_LOGFILE}
    #fi
}

#############################################################################
#    Func Name: get_temp_dir
# Date Created: 2011-07-18
#       Author: guozhonghua/02084
#  Description: get the temp directory to store the VMs' data file for backup
#        usage: $0 $1 $2
#               $1 : THE CURRENT TIME
#               $2 : THE VM'S NAME
#               $3 : The temp dir input from front
#               $4 : The backup mode, sufix, 0,10/11,20/22,maybe empty
#       OUTPUT: NONE
#       RETURN: 0  : SUCCESS
#               1  : FAILED
#      CAUTION:
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
#############################################################################
get_temp_dir()
{
    # wrong parameters
    if [ $# -lt 3 ]; then
        return $BR_WRONG_PARAM
    fi

    # Module name for log
    local MODULE_NAME=get_temp_dir

    # get the current time
    current_time=$1

    # the vm's name
    vm_name=$2

    # set the default tmpdir with /
    tmp_dir=$3

    if [ "X$tmp_dir" = "X" ]; then
        defaultsize=0

        # Find out the maxium compacity disk of the host, the directory
        for diskcapacity in $( $DF_CMD | awk 'NR>=2{if($1!="udev"&&$1!="tmpfs"&&$1!="none"){if(index($4, "%")>0){printf("%s=%s\n", $3,$5);} else{ printf("%s=%s\n", $4,$6);}}}' )
        do
            capacity=${diskcapacity%=*}
            dirtemp=${diskcapacity#*=}

            br_printlog $MODULE_NAME debug "The capacity=$capacity directory=$dirtemp"
            if [ "X$dirtemp" = "X/" ] || [ "X$dirtemp" = "X/var/log" ]; then
                br_printlog $MODULE_NAME debug "DONOT use $dirtemp directory, ingnored"
                continue
            fi
            ## empty line, continue
            if test -z $dirtemp || test -z $capacity
            then
                continue
            fi

            # Just look for the ext file system
            is_ocfs2=false
            for network_dir in $( mount | grep type[[:space:]]ext | awk '{print $3}' )
            do
                if [ "X$network_dir" = "X$dirtemp" ]; then
                    local mds_disk=`echo $network_dir | grep '/opt/mds/disk/[[:digit:]]\{1,\}'`
                    #br_printlog $MODULE_NAME debug "network file system: $network_dir, and get MDS path inf $mds_disk"

                    # Wether MDS path
                    if [ "X$mds_disk" != "X" ]; then
                        br_printlog $MODULE_NAME debug "MDS path inf $mds_disk, will be filtered"
                        break
                    fi

                    #br_printlog $MODULE_NAME debug "network file system: $network_dir, $dirtemp"
                    is_ocfs2=true
                    break
                fi
            done

            if [ "X$is_ocfs2" = "Xfalse" ]; then
                br_printlog $MODULE_NAME debug "The $dirtemp file system can not be used, continue"
                continue
            fi

            if [ $capacity -ge $defaultsize ]; then
                defaultsize=$capacity
                tmp_dir=$dirtemp
            fi
        done

        # if get the disk capacity failed
        if [ $defaultsize -eq 0 ]; then
            br_printlog $MODULE_NAME err "Get the capacity of the disks failed"
            return $BR_DISK_SPACE_NO_ENOUGH
        fi

        #echo "Find the maxium capacity disk with the directory = "$tmp_dir
        #br_printlog $MODULE_NAME debug "Find the dir $tmp_dir with capacity $defaultsize"

        # if it is the root directory
        if [ "$tmp_dir" = "/" ]; then
            tmp_dir=""
            return $BR_MAKE_DIRS
        fi
    fi
    has_vmbackuptmp=`echo $tmp_dir | grep vmbackuptmp`
    if [ "X$has_vmbackuptmp" = "X" ] ; then
       tmp_dir=$tmp_dir"/vmbackuptmp"
    fi

    # Create one directory
    vm_temp_dir=$tmp_dir"/"$vm_name"_"$current_time

    if [ $# -ge 4 ]; then
        vm_temp_dir=$tmp_dir"/"$vm_name"_"$current_time"_"$4
    fi

    mkdir -p $vm_temp_dir
    if [ $? -ne 0 ]; then
        br_printlog $MODULE_NAME err "Make temp directory failed"
        return $BR_MAKE_DIRS
    fi

    if test -e $vm_temp_dir; then
        echo $vm_temp_dir
    else
        return $BR_MAKE_DIRS
    fi

    # successfully
    return $BR_SUCCESS
}

##############################################################################
#    Func Name: cp_data_file
# Date Created: 2011-07-18
#       Author: guozhonghua/02084
#  Description: cp file to another directory
#        usage: $0 $1 $2
#               $1 : the original directory
#               $2 : the destination directory
#       OUTPUT: NONE
#       RETURN: 0  : SUCCESS
#               1  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
cp_data_file()
{
    # Module name for log
    local MODULE_NAME=cp_data_file

    # wrong parameters
    if [ $# -lt 2 ]; then
       br_printlog $MODULE_NAME err "Parameters error"
       return $BR_WRONG_PARAM
    fi

    # get the original directory
    original_dir="$1"

    # move all file to directory $2
    cp -r $original_dir $2
    return_code=$?
    if [ $return_code -ne 0 ]; then
        br_printlog $MODULE_NAME err "Copy files failed with $return_code"
        return $BR_COPY_FILE_FAILED
    fi
    return $BR_SUCCESS
}

##############################################################################
#    Func Name: ftp_data_file_transfer
# Date Created: 2011-07-18
#       Author: guozhonghua/02084
#  Description: transfer files through ftp
#        usage: ftp_data_file_transfer 192.168.0.107 21 gzh 1q2w3e test get
#               ftp_data_file_transfer 192.168.0.107 21 gzh 1q2w3e test put
#            $1 server ip or host name
#            $2 ftp server port
#            $3 user name
#            $4 user'a password
#            $5 directory on the ftp server
#            $6 the VM directory to be built
#            $7 put or get
#       OUTPUT: NONE
#       RETURN: 0  : SUCCESS
#               1  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
ftp_data_file_transfer()
{
    # Module name for log
    local MODULE_NAME=ftp_data_file_transfer

    # echo $@
    case $7 in
        "put")
            result_values=`ftp -n -i $1 $2 <<EOF
            user $3 "$4"
            cd $5
            binary
            mkdir $6
            cd $6
            #prompt
            mput *.gz
            mput *.conf
            mput *.xml
            mput info
            mput backup_version
            #added by zhanglianxiang
            dir . backup_file_info
            bye
EOF`

            return_code=$?
            if [ $return_code -ne 0 ]; then
                br_printlog $MODULE_NAME err "Execute FTP transfer put failed with return code $return_code"
                return $return_code
            fi

            # Parse the error information
            errorinfo=`echo $result_values | grep "Not connected"`
            if [ "X$errorinfo" != "X" ]; then
                return $BR_FTP_TRANSFER_1
            fi

            errorinfo=`echo $result_values | grep "Login failed"`
            if [ "X$errorinfo" != "X" ]; then
                return $BR_FTP_TRANSFER_2
            fi

            #use wftp32
            errorinfo=`echo $result_values | grep "The disk is full"`
            if [ "X$errorinfo" != "X" ]; then
                return $BR_DISK_SPACE_NO_ENOUGH
            fi

            errorinfo=`echo $result_values | grep "$5"`
            if [ "X$errorinfo" != "X" ]; then
                return $BR_FTP_TRANSFER_3
            fi

            errorinfo=`echo $result_values | grep "$6"`
            if [ "X$errorinfo" != "X" ]; then
                return $BR_FTP_TRANSFER_3
            fi

            # no privileges
            errorinfo=`echo $result_values | grep "Permission denied"`
            if [ "X$errorinfo" != "X" ]; then
                return $BR_FTP_TRANSFER_4
            fi
            ;;

        "get")
            result_values=`ftp -n -i $1 $2 <<EOF
            user $3 "$4"
            cd $5
            binary
            cd $6
            #prompt
            mget *
            bye
EOF`
            echo "FTP result values="$result_values
            return_code=$?
            if [ $return_code -ne 0 ]; then
                br_printlog $MODULE_NAME err "Execute FTP transfer get failed with return code $return_code"
                return $return_code
            fi

            errorinfo=`echo $result_values | grep "Not connected"`
            if [ "X$errorinfo" != "X" ]; then
                return $BR_FTP_TRANSFER_1
            fi

            errorinfo=`echo $result_values | grep "Login failed"`
            if [ "X$errorinfo" != "X" ]; then
                return $BR_FTP_TRANSFER_2
            fi

            errorinfo=`echo $result_values | grep "$5"`
            if [ "X$errorinfo" != "X" ]; then
                return $BR_FTP_TRANSFER_3
            fi

            errorinfo=`echo $result_values | grep "$6"`
            if [ "X$errorinfo" != "X" ]; then
                return $BR_FTP_TRANSFER_3
            fi

            #added by zhanglianxiang
            dir=`pwd`
            check_up_backup_file_4_restore $dir
            return_code=$?
            if [ $return_code != 0 ]; then
                br_printlog $MODULE_NAME err "FTP files failed with get with code $return_code"
                return $return_code
            fi
            #end
            ;;
        *)
            br_printlog $MODULE_NAME err "Unknown parameters for ftp transfer"
            return $BR_FTP_UNSUPORTTED_OPERATION
            ;;
    esac
    return $BR_SUCCESS
}

##############################################################################
#    Func Name: utils_is_ipv6
# Date Created: 2018-9-26
#       Author: tuguoyi/14581
#  Description: Check if it's ipv6 address
#        usage:
#       Input:
#            $1 ip
#       OUTPUT: NONE
#       RETURN: the remote path string
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
utils_is_ipv6()
{
    # set the module name
    local ip=$1
    
    local count=`echo $ip | awk -F ':' '{print NF}'`
    if [ $count -gt 1 ]; then
        echo 1
    else
        echo 0
    fi
}

##############################################################################
#    Func Name: utils_get_compat_ip
# Date Created: 2018-9-26
#       Author: tuguoyi/14581
#  Description: Provide a generic api to get ip addr. if IP is a link-local ipv6 address, 
#               the interface name(vswitch0) will be append to it, otherwise the same ip will be returned
#        usage:
#       Input:
#            $1 host ip
#       OUTPUT: NONE
#       RETURN: the remote path string
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
utils_get_compat_ip()
{
    # set the module name
    local MODULE_NAME=utils_get_compat_ip

    local host_ip=$1
    local compat_ip=`python3 $BR_SHELL_PATH"/"br_ipcompat_util.pyc get_compat_ip $host_ip`
    if [ $? -ne 0 ]; then
        br_printlog $MODULE_NAME err "Failed to get compat ip, return the ip directly. input params: $@"
        compat_ip=$host_ip
    fi
    echo $compat_ip
}

##############################################################################
#    Func Name: utils_get_scp_remote_path
# Date Created: 2018-9-26
#       Author: tuguoyi/14581
#  Description: Generate IPv4/IPv6 compatible remote path with supplied arguments 
#        usage:
#       Input:
#            $1 host ip
#            $2 username
#            $3 directory on the remote server
#       OUTPUT: NONE
#       RETURN: the remote path string
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
utils_get_scp_remote_path()
{
    # set the module name
    local MODULE_NAME=utils_get_scp_remote_path

    br_printlog $MODULE_NAME debug "input params: $@"
    local host_ip=$1
    local username=$2
    local path=$3

    local scp_path=`python3 $BR_SHELL_PATH"/"br_ipcompat_util.pyc get_scp_path $host_ip $username "$path"`
    if [ $? -ne 0 ]; then
        br_printlog $MODULE_NAME err "Failed to get scp path. input params: $@"
        scp_path=""
    fi
    echo $scp_path
}


##############################################################################
#    Func Name: scp_data_file_transfer
# Date Created: 2011-07-18
#       Author: guozhonghua/02084
#  Description: scp the backup directory to the remote server
#        usage:
#        Examples:
#                 expect file_scp.exp ./temp/ftptest.sh root@192.168.0.5:/tmp/gzhtest 22 1q2w3e
#                 expect file_scp.exp root@192.168.0.5:/root/gzh/* ./temp 22 1q2w3e
#                 scp_data_file_transfer 192.168.0.5 22 root 1q2w3e /tmp/gzhtest /root/shell_test/temp/scptest get
#                 scp_data_file_transfer 192.168.0.5 22 root 1q2w3e /tmp/gzhtest /root/shell_test/temp/scptest put
#       Input:
#            $1 server ip or host name
#            $2 server port
#            $3 user name
#            $4 user'a password
#            $5 directory on the remote server
#            $6 local diretory
#            $7 put or get
#       OUTPUT: NONE
#       RETURN: 0  : SUCCESS
#               1  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
scp_data_file_transfer()
{
    # set the module name
    local MODULE_NAME=scp_data_file_transfer

    #by caizhifeng for temp
    br_printlog $MODULE_NAME info "input params: $1 $2 $3 @@@ $5 $6 $7"

    local user="$3"
    local passwd="$4"

    # send file to remote server or get data file from remote server
    case $7 in
    "put")
        expect $BR_SHELL_PATH"/"file_ssh_mkdir.exp "$user"@"$1" $2 $5 "$passwd" >/dev/null
        return_code=$?
        if [ $return_code -ne 0 ]; then
            br_printlog $MODULE_NAME err "make directory failed $return_code"
            return $return_code
        fi

        # send files, should do send it for every file
        for files in `ls $6`
        do
            remote_path=`utils_get_scp_remote_path $1 $user $5`
            expect $BR_SHELL_PATH"/"file_scp.exp $6"/"$files "$remote_path" $2 "$passwd" >/dev/null
            return_code=$?
            if [ $return_code -ne 0 ]; then
                br_printlog $MODULE_NAME err "SCP files failed with put with code $return_code"
                return $return_code
                fi
        done

        #by caizhifeng for temp
        br_printlog $MODULE_NAME info "PUT scp ok!!!"
        ;;
    "get")
        # get all files from remote server
        remote_path=`utils_get_scp_remote_path $1 $user "$5"`
        expect $BR_SHELL_PATH"/"file_scp.exp "$remote_path" $6 $2 "$passwd" >/dev/null
        return_code=$?
        if [ $return_code -ne 0 ]; then
            # log error
            br_printlog $MODULE_NAME err "SCP files failed with get with code $return_code"
            return $return_code
        fi
        ;;
    *)
        br_printlog $MODULE_NAME err "VM xml file define failed"
        return $BR_SCP_UNSUPORTTED_OPERATION
        ;;
    esac
    return $BR_SUCCESS
}

##############################################################################
#    Func Name: vm_br_confg_valid_cp
# Date Created: 2012-09-03
#       Author: guozhonghua/02084
#  Description: vm backup parameters validation test, local directory
#        usage:
#       Input: $1 directory on the remote server
#       OUTPUT: NONE
#       RETURN: 0      : SUCCESS
#               Other  : FAILED,error code
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
vm_br_confg_valid_cp()
{
    if ! test -d $1 ; then
        return $BR_DIRECTORY_ERROR
    fi

    # the directory can not write
    if ! test -w $1 ; then
        return $BR_DIRECTORY_ERROR
    fi
    return $BR_SUCCESS
}

