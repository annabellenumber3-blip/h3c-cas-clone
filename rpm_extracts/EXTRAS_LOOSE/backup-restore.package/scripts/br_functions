##############################################################################
#    Func Name: extract_tar_file()
# Date Created: 2015-01-07
#       Author: linjunsheng/kf5383
#  Description: extract the tar  file
#        usage: extract_tar_file -xf file
#            $1 filename
#       OUTPUT: NONE
#       RETURN: NULL
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
##############################################################################
extract_tar_file()
{
    local MODULE_NAME=extract_tar_file
    local file_for_extract=$1
    file_for_extract=${file_for_extract##*/}
    # extract the tar file
    br_printlog $MODULE_NAME debug "$LINENO:extract the tar file $file_for_extract"
    tar -xf $file_for_extract
    local rtn_code=$?
    if [ $rtn_code -ne 0 ]; then
        br_printlog $MODULE_NAME err "$LINENO:extract the file failed with error code $rtn_code"
        local dir=${file_for_extract%.*}
        clean_backup_file_local $file_for_extract
        clean_backup_file_local $dir
        exit $BR_TAR_X
    fi
    clean_backup_file_local $file_for_extract
    br_printlog $MODULE_NAME debug "$LINENO:remove the tar file $file_for_extract"
}

###########################################################################
#  Name   : check_store_type
#  Author : zhanglianxiang/09608
#  Create : 2013-05-21
#  Desp   : check multi backing file of disk in vm conf file when restore.
#
#       $1: conf file
#       RETURN: 0  : store type is iscsi or lvm or raw
#               1  : store type is qcow
#               2  : store type failed
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
############################################################################
check_store_type()
{
    local module_name=check_store_type
    local type=""
    local type_tmp=""
    local conf=""
    conf=$1
    br_printlog $module_name info "conf = $conf, pwd =`pwd`,all file = `ls` "
    type=`cat $conf | awk '{print $2}'`
    br_printlog $module_name info "type = $type"
    if [ "X$type" != "X" ]; then
        type_tmp=`echo $type | grep -E "ISCSI|RAW|LVM"`
        if [ "X$type_tmp" != "X" ]; then
            return $BR_BACKUP_NOT_QCOW
        else
            return $BR_BACKUP_QCOW
        fi
    else
        return $BR_UNKNOWN_DATA_FILE_FORMAT
    fi
}

###########################################################################
#   Name  : check_disk_space
#  Author : zhanglianxiang/09608
#  Create : 2013-05-21
#  Desp   : check destination disk space for VM incr restored
#       $1: para shift
#       $2: temp dir for restore
#       $3: destination data file directory, using * as separetor, such as: data_file=/var/lib/libvirt/imagas
#       $4: destination data file directory, using * as separetor, such as: data_file=/var/lib/libvirt/imagas... ...
#       RETURN: 0  : SUCCESS
#          others  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
############################################################################
check_disk_space()
{
    # Module name for log
    local MODULE_NAME=check_disk_space

    # arrays for dir_size recodes size of images
    declare -A dir_size
    declare -A dir0
    declare -A cur_ndisk
    declare -A final_ndisk
    declare -A now_ndisk

    local dir_tmp_restore=$1

    # parse the VM's conf file
    local vm_name=$4
    local vm_date_backup=$5
    local name=$8
    local limited_coe=${10}
    if [ "$2" = "cp" ]; then
        br_printlog $MODULE_NAME info "all params = $@"
        shift 10
    else
        br_printlog $MODULE_NAME info "all params part 1= $1 $2 $3 $4 $5 @@@ $7 $8 $9 ${10} ${11} ${12} ${13} ${14}"
        vm_name=$8
        vm_date_backup=$9
        name=${12}
        limited_coe=${14}
        shift 14
        br_printlog $MODULE_NAME info "all params part 2= $@"
    fi

    # change the directory to the original path
    cd $dir_tmp_restore
    return_code=$?
    if [ $return_code -ne 0 ]; then
        br_printlog $MODULE_NAME err "$LINENO: change to $dir_tmp_restore directory failed  with code $return_code"
        return $BR_CHANGE_DIR_FAILED
    fi

    #check operation is restore or import
    check_restore_mode $vm_name
    if [ $? -eq 0 ]; then
        mode=0
    else
        mode=1
        if [ "X$name" != "X0" ]; then
            check_restore_mode $name
            if [ $? -eq 0 ]; then
                mode=0
            fi
        fi
    fi

    br_printlog $MODULE_NAME info "$LINENO: mode is $mode. 0(restore),1(import)"

    if [ $mode -eq 0 ]; then
        if [ "X$name" != "X0" ]; then
            vm_xml_file=$VMXML_PATH"/"$name".xml"
        else
            vm_xml_file=$VMXML_PATH"/"$vm_name".xml"
        fi
        local all_data_files=`python3 $BR_SHELL_PATH/vm_xml_data_file_print.pyc $vm_xml_file`
        br_printlog $MODULE_NAME info "$LINENO: all_data_files=$all_data_files"
        local cur_tmp_disk=""
        for vm_data_file in $all_data_files
        do
            cur_tmp_disk=`python3 $BR_SHELL_PATH/find_disk.pyc $vm_xml_file $vm_data_file`
            if [ $? -ne 0 -o "$cur_tmp_disk" = "" ]; then
                br_printlog $MODULE_NAME err "$LINENO: get $cur_tmp_disk of $vm_data_file failed"
                return $BR_XML_REPLACE_FAILED
            fi
            cur_ndisk[$cur_tmp_disk]=$vm_data_file
            br_printlog $MODULE_NAME info "$LINENO: cur_ndisk[$cur_tmp_disk] = $vm_data_file"
        done
    fi

    local now_all_data_files=`python3 $BR_SHELL_PATH/vm_xml_data_file_print.pyc *.xml`
    local now_tmp_disk=""
    for vm_data_file in $now_all_data_files
    do
        now_tmp_disk=`python3 $BR_SHELL_PATH/find_disk.pyc *.xml $vm_data_file`
        if [ $? -ne 0 -o "$now_tmp_disk" = "" ]; then
            br_printlog $MODULE_NAME err "$LINENO: get $now_tmp_disk of $vm_data_file failed"
            return $BR_XML_REPLACE_FAILED
        fi
        now_ndisk[$now_tmp_disk]=$vm_data_file
        br_printlog $MODULE_NAME info "$LINENO: now_ndisk[$now_tmp_disk] = $vm_data_file"
    done
    # process every data file
    for org_file_name in $@
    do
        if [ "$org_file_name" = "$BACKUP_SUFFIX_INC_ALL" ] || [ "$org_file_name" = "$BACKUP_SUFFIX_INC" ]; then
            continue
        fi

        if [ "$org_file_name" = "$BACKUP_SUFFIX_DIFF_ALL" ] || [ "$org_file_name" = "$BACKUP_SUFFIX_DIFF" ]; then
            continue
        fi

        local regions=`echo $org_file_name | awk -F "=" '{print NF}'`
        if [ $regions -eq 2 ]; then
            region_nb=1
        else
            region_nb=`echo $org_file_name | awk -F ";" '{print NF}'`
        fi

        # log regions, region_nb
        br_printlog $MODULE_NAME debug "$LINENO: $org_file_name, parsed result: $regions, $region_nb"

        if [ $region_nb -eq 1 ]; then
            if [ $regions -eq 2 ]; then
                r1=$org_file_name
            else
                r1=`echo $org_file_name | awk -F ";" '{print $1}'`
            fi

            src_path=${r1%=*}
            src_name=${src_path##*/}
            dest_path=${r1#*=}
            if [ "X$src_path" = "X" ] || [ "X$dest_path" = "X" ]; then
                br_printlog $MODULE_NAME err "$LINENO: Get info: src_path=$src_path dest_path=$dest_path, failed"
                return $BR_WRONG_PARAM
            fi
            br_printlog $MODULE_NAME debug "$LINENO: src_path=$src_path dest_path=$dest_path"
        elif [ $region_nb -eq 2 ]; then
            r2=`echo $org_file_name | awk -F ";" '{print $2}'`
            backing_src_path=${r2%=*}
            backing_dest_path=${r2#*=}
            if [ "X$backing_src_path" = "X" ] || [ "X$backing_dest_path" = "X" ]; then
                br_printlog $MODULE_NAME err "$LINENO: Get info: backing_org=$backing_src_path backing_dest_path=$backing_dest_path failed."
                return $BR_WRONG_PARAM
            fi
            br_printlog $MODULE_NAME debug "$LINENO: backing_org=$backing_src_path backing_dest_path=$backing_dest_path"

            r1=`echo $org_file_name | awk -F ";" '{print $1}'`
            src_path=${r1%=*}
            src_name=${src_path##*/}
            dest_path=${r1#*=}
            if [ "X$src_path" = "X" ] || [ "X$dest_path" = "X" ]; then
                br_printlog $MODULE_NAME err "$LINENO: Get info: src_path=$src_path dest_path=$dest_path failed"
                return $BR_WRONG_PARAM
            fi
            br_printlog $MODULE_NAME debug "$LINENO: Get info: src_path=$src_path dest_path=$dest_path "
        elif [ $region_nb -eq 3 ]; then
            r3=`echo $org_file_name | awk -F ";" '{print $3}'`
            double_backing_src_path=${r3%=*}
            double_backing_dest_path=${r3#*=}
            if [ "X$double_backing_src_path" = "X" ] || [ "X$double_backing_dest_path" = "X" ]; then
                br_printlog $MODULE_NAME err "$LINENO: double_backing_src_path=$double_backing_src_path double_backing_dest_path=$double_backing_dest_path"
                return $BR_WRONG_PARAM
            fi
            br_printlog $MODULE_NAME debug "$LINENO: Get info: double_backing_src_path=$double_backing_src_path double_backing_dest_path=$double_backing_dest_path"

            r2=`echo $org_file_name | awk -F ";" '{print $2}'`
            #NOTE:backing_src_path=/vms/images/backing,backing_dest_path=/vms/images
            backing_src_path=${r2%=*}
            backing_dest_path=${r2#*=}
            if [ "X$backing_src_path" = "X" ] || [ "X$backing_dest_path" = "X" ]; then
                br_printlog $MODULE_NAME err "$LINENO: Get info: backing_org=$backing_src_path backing_dest_path=$backing_dest_path failed"
                return $BR_WRONG_PARAM
            fi
            br_printlog $MODULE_NAME debug "$LINENO: Get info: backing_org=$backing_src_path backing_dest_path=$backing_dest_path OK"

            r1=`echo $org_file_name | awk -F ";" '{print $1}'`
            src_path=${r1%=*}
            src_name=${src_path##*/}
            dest_path=${r1#*=}
            if [ "X$src_path" = "X" ] || [ "X$dest_path" = "X" ]; then
                br_printlog $MODULE_NAME err "$LINENO: Get info: src_path=$src_path dest_path=$dest_path failed"
                return $BR_WRONG_PARAM
            fi
            br_printlog $MODULE_NAME debug "$LINENO: Get info: src_path=$src_path dest_path=$dest_path OK"
        else
            br_printlog $MODULE_NAME err "$LINENO: Parse the image files info failed"
            return $BR_WRONG_PARAM
        fi

        local src_disk=""
        src_disk=`python3 $BR_SHELL_PATH/find_disk.pyc "/tmp/br_vm_xml/"$vm_name"_"$vm_date_backup".xml" $src_path`
        if [ $? -ne 0 -o "$src_disk" = "" ]; then
            br_printlog $MODULE_NAME err "$LINENO: get $src_disk of $src_path failed"
            return $BR_XML_REPLACE_FAILED
        fi

        is_rbd=`echo $dest_path | egrep '^rbd:'`
        if [ "X$is_rbd" != "X" ]; then
            image_name=${dest_path#*:}
            pool_name=${image_name%%/*}
            config_file=`python3 /opt/bin/get_conf_for_rbd_by_pool.pyc $pool_name`
            if [ $? -ne 0 -o "$config_file" = "" ]; then
                br_printlog $MODULE_NAME err "$LINENO: find config file err for pool:$pool_name."
                return $BR_FAILED
            fi
            data_pool_name=`virsh pool-dumpxml $pool_name | xargs | grep -E -o -e "<source>.*</source>" | grep -E -o -e  "<name>.+</name>" | awk -F ">" '{print $2}' | awk -F "<" '{print $1}'`
            meta_pool_name=`virsh pool-dumpxml $pool_name | xargs | grep -E -o -e  "<metadatapool>.+</metadatapool>" | awk -F ">" '{print $2}' | awk -F "<" '{print $1}'`
        fi


        if [ $mode -eq 0 ] && [ "X$name" = "X0" ]; then
            cur_path=${cur_ndisk[$src_disk]}
            br_printlog $MODULE_NAME info "$LINENO: cur_path=$cur_path, src_disk=$src_disk"
            if [ "X$cur_path" = "X" ]; then
                br_printlog $MODULE_NAME info "$LINENO: PAY ATTATION!!! There is no disk $src_disk for restore!"
                file_format=`echo $src_path | egrep '\-iscsi\-|dm-name-'`
                br_printlog $MODULE_NAME debug "$LINENO: file_format=$file_format"
                if [ "X$file_format" != "X" ]; then
                    br_printlog $MODULE_NAME err "$LINENO: $src_disk is a block device, but this disk is removed!"
                    return $BR_NO_BLOCK_DEVICE
                else
                    is_rbd=`echo $dest_path | egrep '^rbd:'`
                    if [ "X$is_rbd" != "X" ]; then
                        image_name=${dest_path#*:}
                        pool_name=${image_name%/*}
                        image_only_name=${image_name##*/}

                        rbd_type=`cat $RBD_INST_FILE | awk -F " " '{print $1}'`
                        if [ "$rbd_type" = "onestor" ]; then
                            is_rbd_exist=`$RBD_CMD ls --conf $config_file $data_pool_name | egrep "^"$image_only_name"\$"`
                        else
                            is_rbd_exist=`$RBD_CMD ls $data_pool_name | egrep "^"$image_only_name"\$"`
                        fi
                        if [ "X$is_rbd_exist" != "X" ];then
                            br_printlog $MODULE_NAME err "$LINENO: ATTATION!!!dest_path=$dest_path is exist, please check whether $dest_path has been used by other vm."
                            return $BR_BACKUP_FILE_EXIST
                        fi
                    else
                        test -e $dest_path
                        if [ $? -eq 0 ]; then
                            br_printlog $MODULE_NAME err "$LINENO: ATTATION!!!dest_path=$dest_path is exist, please check whether $dest_path has been used by other vm."
                            return $BR_BACKUP_FILE_EXIST
                        fi
                    fi
                fi
            else
                # fix by f18671: disk may be imported as cur_name when the backup import as another vm
                snap_type=`get_snaptype_by_file`
                if [ "$snap_type" = "external" ]; then
                    cur_base_path=`python3 /opt/bin/find_disk_external.pyc base $vm_xml_file $cur_path`
                    if [ "X$cur_base_path" = "X" -o $? -ne 0 ]; then
                        br_printlog $MODULE_NAME err "$LINENO: Get current base path of $cur_path failed."
                        return $BR_GET_DISK_INFO
                    fi
                    src_base_path=`grep -F "$src_disk" vm_backing_info | awk '{print $NF}'`
                    cur_base_name=${cur_base_path##*/}
                    src_base_name=${src_base_path##*/}
                    cur_name=${cur_path##*/}
                    cur_exist=`grep -w "$cur_base_name" vm_backing_info`
                    if [ "$cur_base_name" != "$src_base_name" ] && [ "${src_name%_inc_*}" != "${cur_base_name%_inc_*}" ] && \
                    [ "$cur_name" != "$src_name" ] && [ "${cur_name%_inc_*}" != "${src_name%_inc_*}" ] && [ "X$cur_exist" = "X" ] && [ "${cur_name%_base_1}" != "${src_name%_base_*}" ]; then
                        br_printlog $MODULE_NAME err "$LINENO: $src_disk file between backup base file $src_base_name or $src_name and current base file $cur_base_name are not the same."
                        return $BR_DISK_CHANGED
                    fi
                else
                    cur_name=${cur_path##*/}
                    if [ "$cur_name" != "$src_name" ] && [ "${cur_name%_inc_*}" != "${src_name%_inc_*}" ] && [ "${cur_name%_base_1}" != "${src_name%_base_*}" ]; then
                        br_printlog $MODULE_NAME err "$LINENO: $src_disk file between backup file $src_name and current file $cur_name are not the same."
                        return $BR_DISK_CHANGED
                    fi
                fi
                dest_path=$cur_path
                if [ "$dest_path" != "$cur_path" ];then
                    br_printlog $MODULE_NAME info "$LINENO:The vm=$vm_name'disk had migrated or changed, change the destination to dest_path=$dest_path"
                fi
            fi
        fi

        now_path=${now_ndisk[$src_disk]}
        now_name=${now_path##*/}
        br_printlog $MODULE_NAME info "$LINENO:now_path=$now_path,now_name=$now_name"
        if [ "$src_path" != "$now_path" ]; then
            src_path=$now_path
            br_printlog $MODULE_NAME info "$LINENO:The vm=$vm_name had migrated, src_path=$src_path,now_path=$now_path"
        fi

        is_rbd=`echo $dest_path | egrep '^rbd:'`
        if [ $mode -eq 1 ]; then
            if [ "X$is_rbd" != "X" ]; then
                image_name=${dest_path#*:}
                pool_name=${image_name%/*}
                image_only_name=${image_name##*/}

                rbd_type=`cat $RBD_INST_FILE | awk -F " " '{print $1}'`
                if [ "$rbd_type" = "onestor" ]; then
                    is_rbd_exist=`$RBD_CMD ls --conf $config_file $data_pool_name | egrep "^"$image_only_name"\$"`
                else
                    is_rbd_exist=`$RBD_CMD ls $data_pool_name | egrep "^"$image_only_name"\$"`
                fi
                if [ "X$is_rbd_exist" != "X" ];then
                    br_printlog $MODULE_NAME err "$LINENO: ATTATION!!!dest_path=$dest_path is exist, please check whether $dest_path has been used by other vm."
                    return $BR_BACKUP_FILE_EXIST
                fi
            else
                test -e $dest_path
                if [ $? -eq 0 ]; then
                    br_printlog $MODULE_NAME err "$LINENO: ATTATION!!!dest_path=$dest_path is exist, please check whether $dest_path has been used by other vm."
                    return $BR_BACKUP_FILE_EXIST
                fi
            fi
        fi

        # The file format type
        file_type=`grep -F "$src_path " *.conf | awk '{printf("%s\n", $2)}'`
        if [ "X$file_type" = "X" ]; then
            br_printlog $MODULE_NAME err "Error index file type for $src_path"
            return $BR_ERROR_FILE_FORMAT
        fi

        # get inc file size
        if [ "X$is_rbd" != "X" ]; then
            image_name=${dest_path#*:}
            pool_name=${image_name%/*}
            image_only_name=${image_name##*/}

            rbd_type=`cat $RBD_INST_FILE | awk -F " " '{print $1}'`
            if [ "$rbd_type" = "onestor" ]; then
                is_rbd_exist=`$RBD_CMD ls --conf $config_file $data_pool_name | egrep "^"$image_only_name"\$"`
            else
                is_rbd_exist=`$RBD_CMD ls $data_pool_name | egrep "^"$image_only_name"\$"`
            fi
            if [ "X$is_rbd_exist" = "X" ];then
                # rbd not exist
                file_size_original=`grep -F "$src_path " *.conf | awk '{printf("%s\n", $3)}'`
                mp="rbd"
                dir0[$mp]="$mp"
                dir_size[$mp]=`expr ${dir_size[$mp]} + $file_size_original`
                br_printlog $MODULE_NAME info "$LINENO: dest_path = $dest_path dir_size[$mp] = ${dir_size[$mp]}"
            fi
        else
            if [ ! -e $dest_path ]; then
                tmp_dir=${dest_path%/*}

                file_size_original=`grep -F "$src_path " *.conf | awk '{printf("%s\n", $3)}'`
                mp=`$DF_CMD $tmp_dir | sed -n '$p' | awk '{printf("%s\n",$6)}'`
                dir0[$mp]="$mp"
                dir_size[$mp]=`expr ${dir_size[$mp]} + $file_size_original`
                br_printlog $MODULE_NAME info "$LINENO: dest_path = $dest_path tmp_dir = $tmp_dir dir_size[$mp] = ${dir_size[$mp]}"
            fi
        fi
    done

    # orig dir VS dest dir
    if [ ${#dir0[@]} != 0 ]; then
        for d in ${dir0[*]}
        do
            if [ "$d" = "rbd" ]; then
                # all ceph rbd pool share the same space
                rbd_type=`cat $RBD_INST_FILE | awk -F " " '{print $1}'`
                if [ "$rbd_type" = "onestor" ]; then
                    capacity_info=`/opt/bin/util_ceph_pool_stat.sh $meta_pool_name $data_pool_name $config_file`
                else
                    capacity_info=`/opt/bin/util_ceph_pool_stat.sh $data_pool_name`
                fi
                dest_disk_space=`echo $capacity_info | awk -F "\"max_avail\":" '{print $2}' | awk -F '}' '{print $1}'`
                dest_disk_space=`expr $dest_disk_space \* 1024`
            else
                dest_disk_space=`$DF_CMD -B1 $d | sed -n '$p' | awk '{printf("%s\n",$4)}'`
                total_space=`$DF_CMD -B1 $d | sed -n '$p' | awk '{printf("%s\n",$2)}'`
                pool_info=`python3 /opt/bin/check_share_stor_by_path.pyc $d`
                if [ $? -ne 0 ]; then
                    br_printlog $MODULE_NAME debug "$LINENO: Check pool $d type failed."
                else
                    pool_type=${pool_info%,*}
                    if [ "$pool_type" = "share" -a $limited_coe -ge 0 ]; then
                        pool_used=${pool_info#*,}
                        dest_disk_space=`echo "$total_space * (1 + $limited_coe) - $pool_used" | bc`
                    fi
                fi
            fi
            if [ "X$dest_disk_space" = "X" ]; then
                br_printlog $MODULE_NAME err "$LINENO: The $d does not have any space"
                return $BR_DISK_SPACE_NO_ENOUGH
            fi

            br_printlog $MODULE_NAME info "$LINENO: dest_disk_space = $dest_disk_space,dir_size[$d] = ${dir_size[$d]}"
            if [ $dest_disk_space -lt ${dir_size[$d]} ]; then
                br_printlog $MODULE_NAME err "$LINENO: $dest_disk_space -lt ${dir_size[$d]},not enough disk space."
                return $BR_DISK_SPACE_NO_ENOUGH
            fi
        done
    fi

    return $BR_SUCCESS
}

###########################################################################
#  Name   : create_inc_xml
#  Author : zhanglianxiang/09608
#  Create : 2013-05-21
#  Desp   : check destination disk space for VM incr restored
#       $1: vm xml
#       $2: vm name
#       $3: mode
#       $4: suffix
#       RETURN: 0  : SUCCESS
#          others  : FAILED
#      CAUTION:
#-----------------------------------------------------------------------------
#  MODIFICATION HISTORY
#  DATE        NAME             DESCRIPTION
############################################################################
create_inc_xml()
{
    local MODULE_NAME=create_inc_xml
    local xml=$1
    local vm_name=$2
    local mode=$3
    if [ "X$4" != "X" ]; then
        local suffix="_$4"
    else
        local suffix=""
    fi
    br_printlog $MODULE_NAME info "$xml $vm_name $mode $suffix"
    python3 $BR_SHELL_PATH/vm_new_incrementXML.pyc $xml $vm_name $mode $suffix
    rtn_code=$?
    if [ $rtn_code != 0 ]; then
        br_printlog $MODULE_NAME err "create incrmental xml file $VM_NAME failed"
        virsh resume $VM_NAME
        if [ $? != 0 ]; then
            br_printlog $MODULE_NAME err "virsh resume $VM_NAME failed"
        fi
        return $BR_CREATE_SNAPSHOT_XML
    fi

    if [ ! -f $vm_inc_xml ]; then
        virsh resume $VM_NAME
        if [ $? != 0 ]; then
            br_printlog $MODULE_NAME err "create incrmental xml file $VM_NAME failed"
        fi
        return $BR_CREATE_SNAPSHOT_XML
    fi

    return $BR_SUCCESS
}

