/var/log/castools/castools.log {
    missingok
    rotate 30
    compress
    copytruncate
    size 512000
    dateext
    dateformat -%Y%m%d.%s
}

/var/log/castools/sysprep.log {
    missingok
    rotate 30
    compress
    copytruncate
    size 512000
    dateext
    dateformat -%Y%m%d.%s
}

/var/log/castools/dev_pts*.log {
    missingok
    rotate 30
    compress
    copytruncate
    size 102400
    dateext
    dateformat -%Y%m%d.%s
}
