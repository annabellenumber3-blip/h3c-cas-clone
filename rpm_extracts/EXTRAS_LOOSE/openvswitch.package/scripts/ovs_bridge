OVS_SHELL_SCRIPT_PATH="/opt/bin"
distri=$(/opt/bin/os_lsb_release -is)
. ${OVS_SHELL_SCRIPT_PATH}/ovs_shellfuncs
. ${OVS_SHELL_SCRIPT_PATH}/ovs_returncodes

shellname="ovs_bridge.sh"
CVK_CONFIG_PATH="/etc/cvk"
LINUX_BOND_BASE=/sys/class/net
LINUX_BOND_MASTERS_BASE=$LINUX_BOND_BASE/bonding_masters
LINUX_BOND_MODE_INIT="active-backup" # active-backup, 1; others: 2, 4
LINUX_BOND_MIIMON_INIT=100 # default 100ms
LINUX_BOND_POLICY_INIT="layer2"
CVK_LINUX_BOND_CONF_PATH=$CVK_CONFIG_PATH/linux_bonding.cfg
BASH=/bin/bash
SHELL_CLEAR_VF=$OVS_SHELL_SCRIPT_PATH/smart_clear_vf.sh
SHELL_LAG_CONFIG_VF=$OVS_SHELL_SCRIPT_PATH/smart_lag_config_vf.sh
SHELL_LINUX_NETWORK=$OVS_SHELL_SCRIPT_PATH/linux_network.sh
SHELL_LINUX_BOND=$OVS_SHELL_SCRIPT_PATH/linux_bond.sh

LINUX_NETWORK_PATH="/etc/linux-engine-networks/vswitch"
LINUX_SUBNET_PATH="/etc/linux-engine-networks/subnets"
WAIT_UPGRADE_FILE="/etc/linux-engine-networks/.wait_upgrade"

OVS_SYSLOG_OFF='--verbose=db_ctl_base:syslog:off'
OVS_LOCK_FILE="/run/ovs_bridge.lock"

die_with_message() {
    local code=$1
    shift
    ovs_printlog ${shellname} err "errorcode: $code, $@"
    exit $code
}

try_lock_ovs_bridge() {
    local br_name=$1
    touch_lock_file $OVS_LOCK_FILE
    ovs_lock $OVS_LOCK_FILE || die_with_message ${OVS_BRIDGE_ERR_REPEAT_CALL_IS_RUNNING} "Process deal with smart vswitch already exists, please wait."
    echo "$br_name" > $OVS_LOCK_FILE
}

release_lock_ovs_bridge() {
    ovs_unlock
    remove_lock_file $OVS_LOCK_FILE
}

