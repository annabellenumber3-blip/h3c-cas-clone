GET_OS_TYPE()
{
    # 获取linux系统类型
    # ret:  "ubuntu-trusty"   # Ubuntu 14.04 LTS
    #       "ubuntu-precise"  # Ubuntu 12.04 LTS
    #       "centos"          # CentOS Linux release 7.4.1708 (Core)
    local os="unknown_os";
    if [ -e /etc/lsb-release ] ; then
        os="ubuntu"
        sub_version=$(/opt/bin/os_lsb_release -c | grep -oP '(?<=:).+' |grep -oP "[[:alnum:]]+")
        os="${os}-${sub_version}"
    elif [ -e /etc/centos-release ]; then
        os="centos"
    fi
    echo ${os}
}

GET_ISSUE()
{
    # 获取linux系统的发行版本
    # ret:  Ubuntu 14.04 LTS
    #       Ubuntu 12.04 LTS
    #       CentOS Linux release 7.4.1708 (Core)
    local issue="";
    if cat /etc/issue | egrep "(Ubuntu)|(ubuntu)" > /dev/null ; then
        #ubuntu
        issue=$( /opt/bin/os_lsb_release -d|grep -oP '(?<=Description:).+' )
    else
        issue=$(cat /etc/redhat-release)
    fi
    echo ${issue}
}


GET_KERNEL_VER()
{
    # 获取linux系统的内核版本
    # echo `uname -r | sed -r s/"[(n)(l)(\)]"/""/g`
    echo `uname -r`
}

CHECK_SSH()
{
    ssh $1 -o ConnectTimeout=5 -o PreferredAuthentications=publickey date 1>&2
    return $?
}
#  --------- Specific Functions -------------

service_register()
{
    # 统一服务注册 —— 提供与操作系统无关的服务注册方式
    # $1 Module/Service Name
    # $2, defaults (optional)，按照默认方式注册服务

    # *目前Ubuntu 12/14下，用法同 update-rc.d
    # *目前CentOS7.x下，基于chkconfig和systemctl的相互兼容性，
    #   实现了兼容处理systemd和systemV服务脚本的注册，但：
    #       对CentOS的systemV服务, 只能处理defaults情况(根据服务脚本配置设置启动和停止)
    #       对CentOS的systemD服务，只能够处理 ".service" 类型脚本
    # TODO: 改成基于systemctl的方式，解决上述问题
    if [ -z "$1" ]; then
        PERROR "<$FUNCNAME>: no module/service specifed! [line:$LINENO]"
        return 2;
    fi
    if which chkconfig &> /dev/null; then
        # CentOS
        if [[ "$@" =~ defaults ]]; then
            if [ -f "/etc/init.d/$1" ]; then
                chkconfig --add $1 || return $?
            fi
            chkconfig $1 on || return $?
        else
            # TODO：特殊参数情况暂按照默认参数处理
            if [ -f "/etc/init.d/$1" ]; then
                chkconfig --add $1 || return $?
            fi
            chkconfig $1 on || return $?
        fi
    elif  which update-rc.d &> /dev/null; then
        # Ubuntu
        update-rc.d $@  || return $?
    else
        PERROR "<$FUNCNAME>: no service tool available! [line:$LINENO]"
        return 1
    fi
}

service_unregister()
{
    # 统一服务注销
    # $1 Module/Service Name
    if [ -z "$1" ]; then
        PERROR "<$FUNCNAME>: no module/service specifed! [line:$LINENO]"
        return 2;
    fi
    if which chkconfig &> /dev/null; then
        # CentOS
        chkconfig $1 off || return $?
        if [ -f "/etc/init.d/$1" ]; then
            chkconfig --del $1 || return $?
        fi
    elif  which update-rc.d &> /dev/null; then
        # Ubuntu
        update-rc.d -f $1 remove || return $?
    else
        PERROR "<$FUNCNAME>: no service tool available! [line:$LINENO]"
        return 1
    fi
}


#  --------- Internal Functions -------------

_install_self()
{
    # Install this shell script to /usr/local/include/
    cd `dirname $0`
    cp `basename $0` $UTIL_INSTALL_DIR
    PINFO "install `basename $0` to $UTIL_INSTALL_DIR"
    PRINT "utils version:${UTIL_VERSION}"
}

_uninstall_self()
{
    # Remove this shell script to /usr/local/include/
    cd `dirname $0`/
    cp `basename $0` $UTIL_INSTALL_DIR
    rm $UTIL_INSTALL_DIR/`basename $0` -f
    PINFO "rm $UTIL_INSTALL_DIR/`basename $0` -f"
}

_usage(){
    # Help information
    echo "Usage:"
    echo -e "  Install: "
    echo -e "\t$0 --install"
    echo -e "\t\tcp `basename $0` to '$UTIL_INSTALL_DIR'"
    echo -e "  Unstall: "
    echo -e "\t$0 --uninstall"
    echo -e "\t\trm `basename $0` in '$UTIL_INSTALL_DIR'"
    echo -e "  Include: "
    echo -e "\t . $0 <MODULE>, <LOG_FILE>"
    echo -e "\t\tinclude `basename $0`, and keep log in /var/log/h3c/LOG_FILE"
    echo -e ""
}


main()
{
    # main process
    if [[ "$0" =~ ^(-bash|-dash|-kash)$ ]] ; then
        PRINT "Shell Utils v${UTIL_VERSION}"
        PINFO "Test mode on."
        PRINT "now, you can test any FUN or VAR..."
        LOG_FILE="$LOG_DIR/$LOG_FILE"
        KEEPLOG=true
        return 0;
    fi
    if [ $# = 0 ] || [ $1 = "-h" ]; then
        _usage
    fi
    if [ "$1" = "--install" ]; then
        UTIL_MODE="install"
        _install_self $@
        exit 0;
    elif [ "$1" = "--uninstall" ]; then
        UTIL_MODE="uninstall"
        _uninstall_self $@
        exit 0;
    fi
    # -设置print标题-
    if [ -n "$1" ]; then
        UTIL_MODE="$1"
    fi
    #-是否记录日志-
    if [ -n "$2" ]; then
        KEEPLOG=true
        LOG_FILE="$2" #日志文件名
        if [ -n "$3"  ]; then
            LOG_DIR="$3"
            # echo "LOG_DIR $LOG_DIR"
        fi
        if [ -n "$4"  ]; then
            LOG_SET_TIME=false
            # echo "LOG_DIR $LOG_DIR"
        fi
        LOG_FILE="$LOG_DIR/$LOG_FILE"
        if [ ! -d $LOG_DIR ]; then
            mkdir -p $LOG_DIR
        fi
        echo "" >> $LOG_FILE
    fi
    # -是否开启调试模式-
    DEBUG_MODE_CHECK
}


main $@

