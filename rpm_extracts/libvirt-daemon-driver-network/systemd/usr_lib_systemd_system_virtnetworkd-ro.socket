[Unit]
Description=Libvirt network local read-only socket
Before=virtnetworkd.service
BindsTo=virtnetworkd.socket
After=virtnetworkd.socket
Conflicts=libvirtd.socket libvirtd-ro.socket libvirtd-admin.socket libvirtd-tcp.socket libvirtd-tls.socket

[Socket]
# The directory must match the /etc/libvirt/virtnetworkd.conf unix_sock_dir setting
# when using systemd version < 227
ListenStream=/var/run/libvirt/virtnetworkd-sock-ro
Service=virtnetworkd.service
SocketMode=0666

[Install]
WantedBy=sockets.target
