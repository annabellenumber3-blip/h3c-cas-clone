[Unit]
Description=Libvirt qemu admin socket
Before=virtqemud.service
BindsTo=virtqemud.socket
After=virtqemud.socket
Conflicts=libvirtd.socket libvirtd-ro.socket libvirtd-admin.socket libvirtd-tcp.socket libvirtd-tls.socket

[Socket]
# The directory must match the /etc/libvirt/virtqemud.conf unix_sock_dir setting
# when using systemd version < 227
ListenStream=/var/run/libvirt/virtqemud-admin-sock
Service=virtqemud.service
SocketMode=0600

[Install]
WantedBy=sockets.target
