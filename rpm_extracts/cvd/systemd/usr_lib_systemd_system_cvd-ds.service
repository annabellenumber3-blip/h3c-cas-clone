[Unit]
Description=cvd ds
Wants=network.service
Wants=libvirtd.service
After=network.service
After=libvirtd.service

[Service]
Type=forking
ExecStart=/usr/sbin/cvd-ds
PIDFile=/var/run/cvd-ds.pid
# Always restart if the service is not running
Restart=always
# Restart after 60 seconds
RestartSec=60
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target

