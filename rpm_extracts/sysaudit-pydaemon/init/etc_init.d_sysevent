#!/bin/bash

#record host events, such as restart, shut down, boot
sysevent="/var/cache/sysevent.log"

case "$1" in
  start)
    #audit_environment_execute $1
    echo "$(date "+%Y/%m/%d %T");start">>$sysevent
  ;;
  stop)
    echo "$(date "+%Y/%m/%d %T");reboot" >>$sysevent
  ;;
  reboot)
  ;;
esac
