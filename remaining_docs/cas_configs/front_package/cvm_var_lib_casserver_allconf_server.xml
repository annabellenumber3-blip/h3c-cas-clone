<!-- 服务器表示表示全局唯一的服务程序。
      一个服务器下可以挂若干资源和若干服务（包括标准服务和定时服务），资源用于各服务共享。
      服务器可以设置的参数如下：
     name：服务器的名称，缺省为“CAMS Standard Server”
     className：服务器使用的实现类，缺省时使用标准的服务器实现类“com.h3c.ead.server.core.StandardServer”；
     port：服务器等候终止命令的端口；
     shutdown：服务器等候的终止命令；当服务器从port端口中侦听到此命令，则停止服务器的运行；
     logLevel：日志级别，有效值包括 "all"; "trace"; "debug"; "info"; "warn"; "error"; "fatal"; "off";
               依据如上顺序，日志记录的信息量逐渐减少；缺省设置为 "info"；
     logPrefix：日志文件前缀，缺省值为 "eadserver."；
     logSuffix：日志文件后缀，缺省值为 ".txt"；
                最终日志文件的文件名为：前缀 + "yyyyMMdd" + 后缀；
-->
<Server port="8010" shutdown="SHUTDOWN" logLevel="info"
    logPrefix="casserver." logSuffix=".txt">

  <!-- 一个资源“Resource”声明，用于代表ead服务中可能使用的资源数据。
       当前的资源主要为数据库链接池资源。
       当className的取值为“com.h3c.ead.server.core.DatabaseResource”时，即生成数据库链接池资源。
       对于数据库链接池资源，有效配置如下所示：
       name：数据库链接池的名称，其他服务使用数据库链接池时，需要使用该名称；
       className：资源实现类，当使用数据库链接池资源时，应为“com.h3c.ead.server.core.DatabaseResource”；
       driverClassName：数据库JDBC驱动名，该属性为必须设置从属性；
       dbUrl：数据库连接使用的URL，该属性为必须设置从属性；
       userName：数据库登录用户名，该属性为必须设置从属性；
       password：数据库登录用户密码，该属性为必须设置从属性；
       initialSize：数据库链接池初始大小，缺省为0；
       maxActive：数据库链接池中的最大池化链接数，缺省为5；
       maxIdle：数据库链接池中，保留的最大闲置链接数，缺省为5；
       minIdle：数据库链接池中，保留的最小闲置链接数，缺省为0；
       maxWait：当所有池化链接均被使用，且已经到达池化链接数最大值时，等待连接释放的毫秒数；
       minEvictableIdleTimeMillis：当连接闲置超过该最小时长时，释放连接；
       defaultAutoCommit：数据库连接是否自动提交，有效值为"true"或"false"，缺省为"true"；
       poolPreparedStatements：指定是否对PreparedStatement进行池化，有效值为"true"或"false"，缺省为false；
       validationQuery：用于检查数据库连接是否有效的查询语句，在数据库连接从连接池中取出时，会自动执行该查询，检验连接是否有效；
       logLevel：日志级别，有效值包括 "all"; "trace"; "debug"; "info"; "warn"; "error"; "fatal"; "off";
                 依据如上顺序，日志记录的信息量逐渐减少；缺省设置继承自 "Server"；
       logPrefix：日志文件前缀，缺省设置继承自 "Server"；
       logSuffix：日志文件后缀，缺省设置继承自 "Server"；
                  最终日志文件的文件名为：前缀 + "yyyyMMdd" + 后缀；
  -->
  <Resource name="CVM JDBC Resource"
    className="com.h3c.cas.server.core.DatabaseResource"
    initialSize="0" maxActive="100" maxIdle="45" minIdle="45" maxWait="5000"
    minEvictableIdleTimeMillis="300000" flag="cvm"
    poolPreparedStatements="false" validationQuery="select version()"/>

