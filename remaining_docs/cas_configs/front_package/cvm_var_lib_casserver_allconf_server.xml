  <!-- 定时服务“TimerService”声明，用于申明一组需要定时执行的任务。其可以包含一个或多个定时任务（TimerTask）。
       对于定时服务，有效配置如下所示：
       name：定时服务的名称；
       className：定时服务实现类，缺省时使用标准的定时服务实现类“com.h3c.ead.server.core.StandardTimerService”；
       logLevel：日志级别，有效值包括 "all"; "trace"; "debug"; "info"; "warn"; "error"; "fatal"; "off";
                 依据如上顺序，日志记录的信息量逐渐减少；缺省设置继承自 "Server"；
       logPrefix：日志文件前缀，缺省设置继承自 "Server"；
       logSuffix：日志文件后缀，缺省设置继承自 "Server"；
                  最终日志文件的文件名为：前缀 + "yyyyMMdd" + 后缀；
  -->
  <TimerService name="Standard Timer Service"
    logLevel="debug" logPrefix="timer." logSuffix=".txt">

    <!-- 一个定时任务“TimerTask”声明，用于申明一项需要定时执行的任务。
         该任务的可使用配置说明如下：
         className：定时任务实现类，该类需继承“com.h3c.ead.server.TimerService”类，且实现“onTimeout”方法；
         dateTimeFields：定时任务的执行时间，该属性的格式为：“* * * * *”，其中：
             第一个“*”表示一分钟内的第几秒钟，范围为 0-59
             第二个“*”表示一小时内的第几分钟，范围为 0-59；
             第三个“*”表示一天内的第几小时，范围为 0-23；
             第四个“*”表示一月内的第几天，范围为 1-31；
             第五个“*”表示一年内的第几月，范围为 1-12；
             第六个“*”表示一周内的第几天，范围为 0-6，0 表示周日；
             其中，当指定了第五个元素（即指定了周为周期时），不能指定第三、第四（日、月为周期）个元素；
             当第三个元素中的数字大于当月的最大日期时（如2月31日），则实际执行日期为当月最后一天；
             例如：
             20 * * * * *             -> 每分钟的第20秒执行；
             0 20 * * * *             -> 每小时的第20分钟0秒执行；
             0 5 22 * * *             -> 每天22时05分0秒执行；
             0 0 8 1 * *              -> 每月1号8时0分0秒执行；
             0 0 8 4 7 *              -> 每年七月四日8时0分0秒执行；
             0 15 12 * * 5            -> 每周五12时15分0秒执行；
             * * 10 * * *             -> 每天10时0分、1分……59分每秒执行；
             0 0 10 * 7 *             -> 七月份每天10点正执行；
             * * * * * *             -> 每秒钟都执行
             0 0 8 * * 1,3,5          -> 每周1、3、5早上8时0分执行；
             0 0 8 1,15 * *           -> 每月1日、15日早上8时0分执行；
             0 0 8-17 * * 1-5         -> 每周1－5，早上8时到下午17时的每小时0分执行；
             0 15-17,19,22 11 * * *   -> 每日早上11时，15分－17分、19分、22分执行。
         startDate：该任务的生效时间，格式为“yyyy-MM-dd HH:mm:ss”,如“2004-12-08 11:47:10”，不设置表示“不限”；
         endDate：该任务的失效时间，格式为“yyyy-MM-dd HH:mm:ss”,如“2005-12-08 11:47:10”，不设置表示“不限”；
         runAtStartup：是否在启动定时服务时，立刻执行该任务？可选值为“true”或“false”，缺省为“false”；
         priority：该任务的优先级。优先级高的任务可能获取更多的CPU资源。
                   有效值包括 "high"; "normal" 和 "low"，缺省为"normal"；
         logLevel：日志级别，有效值包括 "all"; "trace"; "debug"; "info"; "warn"; "error"; "fatal"; "off";
                   依据如上顺序，日志记录的信息量逐渐减少；缺省设置继承自 "Service"；
         logPrefix：日志文件前缀，缺省设置继承自 "Service"；
         logSuffix：日志文件后缀，缺省设置继承自 "Service"；
                    最终日志文件的文件名为：前缀 + "yyyyMMdd" + 后缀；
    -->

