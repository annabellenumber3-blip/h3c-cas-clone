<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
	<Properties>
		<Property name="baseDir">/var/log/casserver</Property>
		<Property name="log_pattern">%d{yyyy-MM-dd HH:mm:ss} [%-5p] [%t] [%C::%M] %m%n</Property>
	</Properties>
	<Appenders>
		<RollingFile name="casserver" fileName="${baseDir}/casserver.log" append="true"
					 filePattern="${baseDir}/casserver.%d{yyyy-MM-dd}-%i.log.gz">
			<PatternLayout Pattern="${log_pattern}"/>
			<Policies>
				<SizeBasedTriggeringPolicy size="100 MB" />
			</Policies>
		</RollingFile>
		<Console name="STDOUT" target="SYSTEM_OUT">
			<PatternLayout pattern="${log_pattern}" />
		</Console>
	</Appenders>
	<Loggers>
		<Logger name="com.h3c.cas.server" level="info" additivity="false">
			<AppenderRef ref="casserver" />
		</Logger>
		<Logger name="com.virtual.plat" level="info" additivity="false">
			<AppenderRef ref="casserver" />
		</Logger>
		<Logger name="com.h3c.h3cloud.snmp.convert" level="info" additivity="false">
			<AppenderRef ref="casserver" />
		</Logger>
		<root level="info">
			<AppenderRef ref="STDOUT" />
		</root>
	</Loggers>
</Configuration>