h3cCasAlarmParamVirtualSwitchErrorPacketRateThreshold OBJECT-TYPE
	SYNTAX	Unsigned32
	UNITS	"%"
	MAX-ACCESS	accessible-for-notify
	STATUS	current
	DESCRIPTION
		"The alarm threshold of error packet rate of a virtual switch."
	::= { h3cCasAlarmParams 120 }

h3cCasAlarmParamNicErrorPacketRateThreshold OBJECT-TYPE
	SYNTAX	Unsigned32
	UNITS	"%"
	MAX-ACCESS	accessible-for-notify
	STATUS	current
	DESCRIPTION
		"The alarm threshold of error packet rate of an NIC."
	::= { h3cCasAlarmParams 121 }

h3cCasAlarmParamAgentTime OBJECT-TYPE
	SYNTAX	DateAndTime
	MAX-ACCESS	accessible-for-notify
	STATUS	current
	DESCRIPTION
		"The current time and date of the agent."
	::= { h3cCasAlarmParams 122 }

h3cCasAlarmParamTomcatConns OBJECT-TYPE
	SYNTAX	Unsigned32
	MAX-ACCESS	accessible-for-notify
	STATUS	current
	DESCRIPTION
		"The number of tomcat connection."
	::= { h3cCasAlarmParams 123 }

h3cCasAlarmParamTomcatConnsThreshold OBJECT-TYPE
	SYNTAX	Unsigned32
	MAX-ACCESS	accessible-for-notify
	STATUS	current
