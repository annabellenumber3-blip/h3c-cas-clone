		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the host enters maintenance mode automatically, which is
		 caused by synchronizing with the CVM. The host will exit maintenance mode once the
		 synchronization is complete or taking more than 10 minutes."
	::= { h3cCasAlarmTrapPrefix 86 }

h3cCasAlarmHostProcessFailed NOTIFICATION-TYPE
