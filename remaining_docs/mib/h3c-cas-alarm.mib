		h3cCasAlarmParamSharedFilesystemName,
		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamSharedFilesystemMountPath,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamDiskIops,
		h3cCasAlarmParamDiskIopsThreshold,
		h3cCasAlarmParamCurrentValue
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when total iops of the shared storage has exceeded
		 the threshold."
	::= { h3cCasAlarmTrapPrefix 36 }

h3cCasAlarmClusterSharedStorageReadIopsExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
