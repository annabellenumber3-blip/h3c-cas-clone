		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamSharedFilesystemMountPath
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when there is only one single link to the shared
		 storage left. This could be caused by the improper upgrading from the old CAS
		 version(before E0218), which can be fixed by manually updating to multipath."
	::= { h3cCasAlarmTrapPrefix 83 }

h3cCasAlarmHostFailed NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the host is malfunctioning. The possible causes
		 could be, 1. the power of the host is unplugged, 2. the host has been shutdown,
		 3. the network connection is broken, 4. password of the host has been modified,
		 or 5. the HA process is malfunctioning."
	::= { h3cCasAlarmTrapPrefix 84 }

h3cCasAlarmVirtualizationManagementServiceAbnormal NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass
	}
