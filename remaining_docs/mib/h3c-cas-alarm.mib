h3cCasAlarmClusterSharedStorageWriteIopsExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamSharedFilesystemName,
		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamSharedFilesystemMountPath,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamDiskWriteIops,
		h3cCasAlarmParamDiskWriteIopsThreshold,
		h3cCasAlarmParamCurrentValue
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when write-IOPS of the shared storage has exceeded
		 the threshold."
	::= { h3cCasAlarmTrapPrefix 38 }

h3cCasAlarmClusterSharedStorageIoLatencyExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
