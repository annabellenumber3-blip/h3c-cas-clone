		h3cCasAlarmParamDiskWriteIoLatency,
		h3cCasAlarmParamDiskWriteIoLatencyThreshold,
		h3cCasAlarmParamCurrentValue
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when write-IO latency(ms) of the shared storage has exceeded
		 the threshold."
	::= { h3cCasAlarmTrapPrefix 41 }

h3cCasAlarmHostSharedStorageFilesystemBroken NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamSharedFilesystemName,
		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamSharedFilesystemMountPath,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamVmMetadataFaultFixResult
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the filesystem of the shared storage is broken. Possible
		 causes are 1. being allocted to non-CVM-controlled system, 2. physical disk damage
		 or 3. being formated or initialized."
	::= { h3cCasAlarmTrapPrefix 42 }

h3cCasAlarmCvmFailed NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvmHostName,
		h3cCasAlarmParamCvmIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when this host has switched to the master CVM, this
		 could be caused by 1. startup of the CVM hot backup service, or 2. failure of the present
		 CVM."
	::= { h3cCasAlarmTrapPrefix 51 }

h3cCasAlarmCasLicenseExpiring NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvmHostName,
		h3cCasAlarmParamCvmIpAddress,
		h3cCasAlarmParamCasType,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the license of the CAS product is abort to expire.
		 Please contact us to get a new license."
	::= { h3cCasAlarmTrapPrefix 52 }

h3cCasAlarmHaStandbyCvmFailed NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvmHostName,
		h3cCasAlarmParamCvmIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the standby CVM of the duplex backup system fails.
		 Which could be caused by 1. failure of the standby CVM, or 2. bad network connecting with
		 the standby CVM."
