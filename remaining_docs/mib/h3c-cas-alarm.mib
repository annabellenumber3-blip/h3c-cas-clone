-- TRAP Definitions
h3cCasAlarmTraps OBJECT IDENTIFIER ::= { h3cCasAlarm 2 }
h3cCasAlarmTrapPrefix OBJECT IDENTIFIER ::= { h3cCasAlarmTraps 0 }

h3cCasAlarmHostNicDown NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicName,
		h3cCasAlarmParamNicMac
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered by a nic failure, which could be
		 caused by a faulty cable connection, or the nic is broken."
	::= { h3cCasAlarmTrapPrefix 1 }

h3cCasAlarmHostLocalStorageFailed NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamDiskName,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered by the failure of the host's local
		 storages, which could be caused by 1. removal of the disk, or 2. the
		 device is broken."
	::= { h3cCasAlarmTrapPrefix 2 }

h3cCasAlarmHostTimeNotSynchronized NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamCvmIpAddress,
		h3cCasAlarmParamTimeDifference,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the time difference between the
		 CVM and the CVK reaches a threshold, which could be caused by 1. the CVK's
		 time inaccuracy, 2. the CVM's time inaccuracy or 3. network abnormalities."
	::= { h3cCasAlarmTrapPrefix 3 }

h3cCasAlarmHostClockSourceNotTsc NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the clock source of the host is not TSC."
	::= { h3cCasAlarmTrapPrefix 4 }

h3cCasAlarmHostCpuUsageExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamCpuUsage,
		h3cCasAlarmParamCpuThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the cpu usage of the host exceeds the
		 threshold, which could be caused by 1. excessive processes, 2. handling of heavy
		 Affairs or 3. excessive running vms. Possible fix would be enabling the
		 Dynamic Resources Scheduling or manually migrating vms to other hosts."
	::= { h3cCasAlarmTrapPrefix 6 }

h3cCasAlarmHostMemUsageExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamMemUsage,
		h3cCasAlarmParamMemThreshold,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the memory usage of the host exceeds the
		 threshold, which could be caused by excessive processes or running vms. Possible
		 fix would be enabling the Dynamic Resources Scheduling or manually migrating
		 vms to other hosts."
	::= { h3cCasAlarmTrapPrefix 7 }

h3cCasAlarmHostDiskPartitionUsageExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamDiskName,
		h3cCasAlarmParamDiskPartitionUsage,
		h3cCasAlarmParamDiskThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the usage of one of the disks of the host
		 exceeds the threshold."
	::= { h3cCasAlarmTrapPrefix 8 }

h3cCasAlarmHostDiskThroughputExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamDiskName,
		h3cCasAlarmParamDiskThroughput,
		h3cCasAlarmParamDiskThroughputThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the total throughput(Mbps) of one of the disks of the
		 host exceeds the threshold."
	::= { h3cCasAlarmTrapPrefix 9 }

h3cCasAlarmHostNetThroughputExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicMac,
		h3cCasAlarmParamNetThroughput,
		h3cCasAlarmParamNetThroughputThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the throughput(Mbps) of one of the nics of the
		 host exceeds the threshold."
	::= { h3cCasAlarmTrapPrefix 10 }

h3cCasAlarmVmFailed NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when a virtual machine fails, which could be caused
		 by 1. virtual machine failures 2. operating system failures of the vm."
	::= { h3cCasAlarmTrapPrefix 11 }

h3cCasAlarmVmFailoverSucceeded NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the HA suceeded in migrating the vm in
		 a faulty state, which could be caused by 1. a vm failure 2. an os failure of the
		 vm or 3. an application failure of the vm."
	::= { h3cCasAlarmTrapPrefix 12 }

h3cCasAlarmVmRecoveryFailed NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the HA failed to recover a vm from fault."
	::= { h3cCasAlarmTrapPrefix 13 }

h3cCasAlarmVmCpuUsageExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamCpuUsage,
		h3cCasAlarmParamCpuThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the cpu usage of the vm exceeds the
		 threshold, which could be caused by 1. excessive processes, 2. handling of heavy
		 Affairs or 3. the use of swap partition of the host."
	::= { h3cCasAlarmTrapPrefix 16 }

h3cCasAlarmVmMemUsageExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamMemUsage,
		h3cCasAlarmParamMemThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the memory usage of the vm exceeds the
		 threshold, which could be caused by 1. excessive processes, 2. handling of heavy
		 Affairs"
	::= { h3cCasAlarmTrapPrefix 17 }

h3cCasAlarmVmDiskPartitionUsageExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamDiskName,
		h3cCasAlarmParamDiskPartitionUsage,
		h3cCasAlarmParamDiskThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the disk usage of the vm exceeds the
		 threshold."
	::= { h3cCasAlarmTrapPrefix 18 }

h3cCasAlarmVmDiskThroughputExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamDiskName,
		h3cCasAlarmParamDiskThroughput,
		h3cCasAlarmParamDiskThroughputThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the throughput(Mbps) of the disk of the vm
		 exceeds the threshold."
	::= { h3cCasAlarmTrapPrefix 19 }

h3cCasAlarmVmNetThroughputExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicMac,
		h3cCasAlarmParamNetThroughput,
		h3cCasAlarmParamNetThroughputThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the throughput(Mbps) of the nic of the vm
		 exceeds the threshold."
	::= { h3cCasAlarmTrapPrefix 20 }

h3cCasAlarmClusterHaFailoverFailed NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamClusterName,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the HA Failover function fails,
		 which could be caused by 1. too many faulty hosts, 2. failure of the cluster
		 storage or 3. the network abnormality."
	::= { h3cCasAlarmTrapPrefix 21 }

h3cCasAlarmHostNetHeartbeatDown NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamClusterName,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the host's network heartbeat with the CVM is down,
		 which could be caused by 1. malfunctioning of the host or 2. abnormal network
		 connection with the host."
	::= { h3cCasAlarmTrapPrefix 22 }

h3cCasAlarmClusterHaResourceReserveInsufficient NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamClusterName,
		h3cCasAlarmParamCpuUsage,
		h3cCasAlarmParamCpuThreshold,
		h3cCasAlarmParamMemUsage,
		h3cCasAlarmParamMemThreshold,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when both the cpu usage and memory usage of the
		 cluster exceed the reserve thresholds."
	::= { h3cCasAlarmTrapPrefix 23 }

h3cCasAlarmClusterCpuUsageExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamClusterName,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamCpuUsage,
		h3cCasAlarmParamCpuThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the cpu usage of the cluster has exceeded the
		 threshold."
	::= { h3cCasAlarmTrapPrefix 26 }

h3cCasAlarmClusterMemUsageExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamClusterName,
		h3cCasAlarmParamMemUsage,
		h3cCasAlarmParamMemThreshold,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the memory usage of the cluster has exceeded the
		 threshold."
	::= { h3cCasAlarmTrapPrefix 27 }

h3cCasAlarmClusterReservedHugepageMemUsageExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamClusterName,
		h3cCasAlarmParamReservedHugepageMemUsage,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamMemReservedHugepageThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the reserved hugepage memory usage of the cluster has exceeded the
		 threshold."
	::= { h3cCasAlarmTrapPrefix 28 }

h3cCasAlarmSharedFilesystemFailed NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamSharedFilesystemName,
		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered by a failure of the shared filesystem, which
		 could be caused by 1. unstable connection between the CVK and the storage device,
		 2. excessive i/o stress of the CVK or the storage device, 3. link concussion or
		 packet delay caused by improper configuration of the adjacent switch, or 4. storage
		 device malfunctioning."
	::= { h3cCasAlarmTrapPrefix 31 }

h3cCasAlarmClusterSharedStorageUsageExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamSharedFilesystemName,
		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamSharedFilesystemMountPath,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamDiskPartitionUsage,
		h3cCasAlarmParamCurrentValue
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the shared storage usage is beyond the threshold."
	::= { h3cCasAlarmTrapPrefix 32 }

h3cCasAlarmClusterSharedStorageThroughputExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamSharedFilesystemName,
		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamSharedFilesystemMountPath,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamDiskThroughput,
		h3cCasAlarmParamDiskThroughputThreshold,
		h3cCasAlarmParamCurrentValue
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when total throughtput of the shared storage has exceeded
		 the threshold."
	::= { h3cCasAlarmTrapPrefix 33 }

h3cCasAlarmClusterSharedStorageReadThroughputExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamSharedFilesystemName,
		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamSharedFilesystemMountPath,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamDiskReadThroughput,
		h3cCasAlarmParamDiskReadThroughputThreshold,
		h3cCasAlarmParamCurrentValue
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when read throughtput of the shared storage has exceeded
		 the threshold."
	::= { h3cCasAlarmTrapPrefix 34 }

h3cCasAlarmClusterSharedStorageWriteThroughputExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamSharedFilesystemName,
		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamSharedFilesystemMountPath,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamDiskWriteThroughput,
		h3cCasAlarmParamDiskWriteThroughputThreshold,
		h3cCasAlarmParamCurrentValue
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when write throughtput of the shared storage has exceeded
		 the threshold."
	::= { h3cCasAlarmTrapPrefix 35 }

h3cCasAlarmClusterSharedStorageIopsExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
