h3cCasAlarmVmFroze NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the vm has been frozen. which could be caused
		 by 1. ocfs2 storage network failure, 2. ocfs2 storage failure."
	::= { h3cCasAlarmTrapPrefix 107 }

h3cCasAlarmVmImgDeleted NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamDiskName,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the vm image file is deleted. which could be caused
		 by 1. image file is deleted by man, 2. image file is deleted by virus."
	::= { h3cCasAlarmTrapPrefix 108 }

h3cCasAlarmVmIOFailOver NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamDiskName
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the vm used storage pool is abnormal and IO of the vm be overed."
	::= { h3cCasAlarmTrapPrefix 109 }

h3cCasAlarmHostLogPartitionGrowSpeedOverExpected NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamUnitTime,
		h3cCasAlarmParamDiskThreshold,
		h3cCasAlarmParamCurrentValue
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the grow speed of the log partition of a vm is
		 over expected. Which could be caused by application malfunctioning. Possible fix
		 would be 1. eliminate the error function or 2. dump the log to another partition.
		 The current value and threshold are in MBs and the unit time is in minutes."
	::= { h3cCasAlarmTrapPrefix 140 }

h3cCasAlarmHostCpuOverheat NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamCpuTemperature,
		h3cCasAlarmParamCpuTemperatureThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the cpu temperature(celsius degree) exceeds the threshold. The
		 possible causes are 1. insufficient thermal dissipation, 2. excessive processes,
		 3. heavy load, or 4. to many running vms."
	::= { h3cCasAlarmTrapPrefix 141 }

h3cCasAlarmHostNicRecvPacketLossOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicMac,
		h3cCasAlarmParamPacketLossRate,
		h3cCasAlarmParamPacketLossThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message trigger when the receiving packet loss rate exceeds the threshold.
		 Which possibly caused by 1. broadcast storm, 2. interfaces not well-connected, or
		 3. firewall rules and network strategies."
	::= { h3cCasAlarmTrapPrefix 142 }

h3cCasAlarmHostNicSendPacketLossOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicMac,
		h3cCasAlarmParamPacketLossRate,
		h3cCasAlarmParamPacketLossThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the sending packet loss rate exceeds the threshold.
		 Which possibly caused by 1. broadcast storm, 2. interfaces not well-connected, or
		 3. firewall rules and network strategies."
	::= { h3cCasAlarmTrapPrefix 143 }

h3cCasAlarmHostMceArose NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when an Machine-Check Exception was reported by the
		 host machine. There are hardware errors in the physical memory, I/O devices or CPU,
		 please refer to /var/log/mcelog or syslog for details."
	::= { h3cCasAlarmTrapPrefix 144 }

h3cCasAlarmVmNicRecvPacketLossOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicMac,
		h3cCasAlarmParamPacketLossRate,
		h3cCasAlarmParamPacketLossThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message trigger when the receiving packet loss rate exceeds the threshold.
		 Which possibly caused by 1. broadcast storm, 2. heavy traffics to the vm, or
		 3. firewall rules and network strategies."
	::= { h3cCasAlarmTrapPrefix 145 }

h3cCasAlarmVmNicSendPacketLossOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicMac,
		h3cCasAlarmParamPacketLossRate,
		h3cCasAlarmParamPacketLossThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the sending packet loss rate exceeds the threshold.
		 Which possibly caused by 1. broadcast storm, 2. heavy traffics from the vm, 3. Apps on
		 the vm take too much network traffic or 4. firewall rules and network strategies."
	::= { h3cCasAlarmTrapPrefix 146 }

h3cCasAlarmCvmFailoverArbitrationHostFailed NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamArbitrationHostName,
		h3cCasAlarmParamArbitrationHostIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when one of the arbitration host of CVM Failover system fails.
		 Which is possibly caused by 1. failure of the arbitration host, or 2. network connection
		 failure to the arbitration host."
	::= { h3cCasAlarmTrapPrefix 147 }

h3cCasAlarmHostSuspiciousProcessRunning NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamArbitrationHostName,
		h3cCasAlarmParamArbitrationHostIpAddress,
		h3cCasAlarmParamSuspiciousProcessName,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"There is a suspicious process running on the CVK host.
		 Possible causes: 1. unwanted softwares are installed, 2. infection of a computer virus."
	::= { h3cCasAlarmTrapPrefix 148 }

h3cCasAlarmHostO2netTcpShutdown NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamFaultyHostName,
		h3cCasAlarmParamFaultyHostIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The TCP connection of ocfs2 management network between the two hosts is shutdown.
		 The problem may be caused by the following reason(s):
		 1. Problems in physical link;
		 2. IP address or port configuration conflicts;
		 3. The other host has been shutdown.
		 Fixes:
		 Check and fix the possible causes listed above."
	::= { h3cCasAlarmTrapPrefix 149 }

h3cCasAlarmSharedStorageMultipathAbnormal NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamStoragePathID,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamStoragePathName,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"One or more links to the shared storage is down. Do check the physical links or the shared
		 storage."
	::= { h3cCasAlarmTrapPrefix 151 }

h3cCasAlarmSharedFilesystemAutomaticallyInactivated NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The shared filesystem is automatically umounted due to access errors in underlying shared storage.
		 Please check the physical links, local networks, host HBA cards or the shared storage."
	::= { h3cCasAlarmTrapPrefix 152 }

h3cCasAlarmHostRestarted NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The host has been restarted, manually or due to a critical error. Please log on to the management
		 interface of the host to screen hardware failures."
	::= { h3cCasAlarmTrapPrefix 153 }

h3cCasAlarmHostVirtualSwitchRecvErrorPacketOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamVirtualSwitchName,
		h3cCasAlarmParamVirtualSwitchErrorPacketRate,
		h3cCasAlarmParamVirtualSwitchErrorPacketRateThreshold
	}
	STATUS	current
	DESCRIPTION
		"The received error packet rate of the virtual switch has exceeded the threshold.
		 This might be caused by 1. physical cable is loosen or broken, 2. being connected to other type of
		 network, 3. non-IP flows.
		 Fixes: 1. Check and fix Network connections errors in including NIC, cable or optical power rate.
		 2. Make sure there are no non-ethernet frames. 3. Make sure there are no unusual non-IP flows."
	::= { h3cCasAlarmTrapPrefix 154 }

h3cCasAlarmHostNicRecvErrorPacketOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicMac,
		h3cCasAlarmParamNicErrorPacketRate,
		h3cCasAlarmParamNicErrorPacketRateThreshold
	}
	STATUS	current
	DESCRIPTION
		"The received error packet rate of the NIC has exceeded the threshold.
		 This might be caused by 1. physical cable is loosen or broken, 2. being connected to other type of
		 network, 3. non-IP flows.
		 Fixes: 1. Check and fix Network connections errors in including NIC, cable or optical power rate.
		 2. Make sure there are no non-ethernet frames. 3. Make sure there are no unusual non-IP flows."
	::= { h3cCasAlarmTrapPrefix 155 }

h3cCasAlarmVmNicRecvErrorPacketOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicMac,
		h3cCasAlarmParamNicErrorPacketRate,
		h3cCasAlarmParamNicErrorPacketRateThreshold
	}
	STATUS	current
	DESCRIPTION
		"The received error packet rate of the NIC has exceeded the threshold.
		 This might be caused by 1. non-IP flows.
		 Fixes: 1. Catch packets at the corresponding vnet interface and check unusual flows."
	::= { h3cCasAlarmTrapPrefix 156 }

h3cCasAlarmIscsiSessionConnectionFailed NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The iscsi session on the CVK host is disconnected."
	::= { h3cCasAlarmTrapPrefix 157 }

h3cCasAlarmHostVirtualSwitchSendErrorPacketOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamVirtualSwitchName,
		h3cCasAlarmParamVirtualSwitchErrorPacketRate,
		h3cCasAlarmParamVirtualSwitchErrorPacketRateThreshold
	}
	STATUS	current
	DESCRIPTION
		"The sent error packet rate of the virtual switch has exceeded the threshold.
		 This might be caused by 1. physical cable is loosen or broken, 2. being connected to other type of
		 network, 3. non-IP flows.
		 Fixes: 1. Check and fix Network connections errors in including NIC, cable or optical power rate.
		 2. Make sure there are no non-ethernet frames. 3. Make sure there are no unusual non-IP flows."
	::= { h3cCasAlarmTrapPrefix 158 }

h3cCasAlarmHostNicSendErrorPacketOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicMac,
		h3cCasAlarmParamNicErrorPacketRate,
		h3cCasAlarmParamNicErrorPacketRateThreshold
	}
	STATUS	current
	DESCRIPTION
		"The sent error packet rate of the NIC has exceeded the threshold.
		 This might be caused by 1. physical cable is loosen or broken, 2. being connected to other type of
		 network, 3. non-IP flows.
		 Fixes: 1. Check and fix Network connections errors in including NIC, cable or optical power rate.
		 2. Make sure there are no non-ethernet frames. 3. Make sure there are no unusual non-IP flows."
	::= { h3cCasAlarmTrapPrefix 159 }

h3cCasAlarmVmNicSendErrorPacketOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamNicMac,
		h3cCasAlarmParamNicErrorPacketRate,
		h3cCasAlarmParamNicErrorPacketRateThreshold
	}
	STATUS	current
	DESCRIPTION
		"The sent error packet rate of the NIC has exceeded the threshold.
		 This might be caused by 1. non-IP flows.
		 Fixes: 1. Catch packets at the corresponding vnet interface and check unusual flows."
	::= { h3cCasAlarmTrapPrefix 162 }
	
h3cCasAlarmTomcatConnsOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvmHostName,
		h3cCasAlarmParamCvmIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamTomcatConns,
		h3cCasAlarmParamTomcatConnsThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the num of tomcat connections exceeded the threshold.
		 This might be caused by 1. tomcat has been visited by too many users.
		 Fixes: contact engineer for help."
	::= { h3cCasAlarmTrapPrefix 165 }

h3cCasAlarmTomcatConnsOfIpOverrate NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvmHostName,
		h3cCasAlarmParamCvmIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamTomcatConns,
		h3cCasAlarmParamTomcatConnsThreshold,
		h3cCasAlarmParamTomcatConnIp
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the num of tomcat connections of singl user exceeded the threshold.
		 This might be caused by 1. connection of tomcat occupied by user exceed the threshold.
		 Fixes: 1. Decrease the conneciton occupied by the user refer to the alarm.
		 2. Contact engineer for help."
	::= { h3cCasAlarmTrapPrefix 166 }

h3cCasAlarmVmTemplateAbnormal NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvmHostName,
		h3cCasAlarmParamCvmIpAddress,
		h3cCasAlarmParamVmTemplateName,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The virtual machine template file is abnormal.
		 This might be caused by 1. The template file is damaged. 2. the template file is not exist.
		 Fixes: 1. Delete abnormal template file and make a new file."
	::= { h3cCasAlarmTrapPrefix 167 }

h3cCasAlarmAdminPwdValidTime NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamUserAccount,
		h3cCasAlarmParamUserPwdValidTime
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the remaining valid days of the administrator account password is less than 7 days.
		This might be caused by 1. remaining valid days of the administrator account password is less than 7 days.
		Fixes: 1. modify the password of administrator account."
	::= { h3cCasAlarmTrapPrefix 168 }

h3cCasAlarmAdminPwdInvalid NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamUserAccount
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when password of the administrator account is invalid.
		This might be caused by 1. password of the administrator account is invalid.
		Fixes: 1. reset the password of administrator account."
	::= { h3cCasAlarmTrapPrefix 169 }

h3cCasAlarmVmMetadataFileFault NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamSharedFilesystemName,
		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamVmMetadataFaultFileName,
		h3cCasAlarmParamVmMetadataFaultFixResult
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when vm file metadata fault was detected by filesystem.
		This might be caused by 1. vm file metadata fault was detected by filesystem."
	::= { h3cCasAlarmTrapPrefix 170 }

h3cCasAlarmVmTcpConnNumberExceedThreshold NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamVmTcpConnNumber,
		h3cCasAlarmParamVmTcpConnNumberThreshold
	}
	STATUS	current
	DESCRIPTION
		"The alarm message triggered when the num of tcp connections of vm exceeded the threshold.
		This might be caused by 1. connection of vm occupied by user exceed the threshold, or 2. the
		 vm is under DDoS attack.
		Fixes: 1. check if vm is under high concurrency, 2. use anti-virus software on the vm."
	::= { h3cCasAlarmTrapPrefix 171 }

h3cCasAlarmAlarmPhoneMessageSendFail NOTIFICATION-TYPE
	OBJECTS {
	    h3cCasAlarmParamPhoneNumber,
	    h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
	    "Alarm message send fail.
	    This might be caused by 1. invalid phone number, 2. invalid message config,
	    3. message server denies services as log in failed too many times.
	    Fixes: 1. check phone number or message config."
	::= { h3cCasAlarmTrapPrefix 172 }

h3cCasAlarmAlarmEmailSendFail NOTIFICATION-TYPE
	OBJECTS {
	    h3cCasAlarmParamSenderEmail,
	    h3cCasAlarmParamRecipientEmail,
	    h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
	    "Alarm email send fail.
	    This might be caused by 1. invalid recipient email address, 2. invalid alarm server,
	    3. email server denies services as log in failed too many times.
	    Fixes: 1. check recipient email address or alarm server, 2. add recipient email address to white list of email server."
	::= { h3cCasAlarmTrapPrefix 173 }

h3cCasAlarmHostVersionFail NOTIFICATION-TYPE
	OBJECTS {
	    h3cCasAlarmParamAlarmClass,
	    h3cCasAlarmParamClusterName,
	    h3cCasAlarmParamEventType,
	    h3cCasAlarmParamAgentTime
	}
	STATUS	current
	DESCRIPTION
	    "The hosts in the cluster are not running the same software version.
	    Possible causes: The hosts are not running the most recent version.
	    Fixes: 1. For features to function correctly, upgrade the hosts in the cluster to the most recent version as soon as possible."
	::= { h3cCasAlarmTrapPrefix 176 }

h3cCasAlarmVmQemuLiveUpdateFail NOTIFICATION-TYPE
	OBJECTS {
	    h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamAlarmClass,
	}
	STATUS	current
	DESCRIPTION
		"QEMU of virtual machine online upgrade fail."
	::= { h3cCasAlarmTrapPrefix 178 }
	
h3cCasAlarmHostHungTask NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamProcessInfo,
		h3cCasAlarmParamAlarmClass,
	}
	STATUS	current
	DESCRIPTION
		"Process is in D state.
		A host process keeps in D state for a long time because it has been waiting for a response from resources.
		Possible reasons: 1. Hardware failure. 2. Storage network anomaly. 3. Insufficient system resources.
		Fixes: Troubleshoot and repair hardware, driver, or storage network faults."
	::= { h3cCasAlarmTrapPrefix 179 }

h3cCasAlarmVmCastoolsAbnormal NOTIFICATION-TYPE
	OBJECTS {
	    h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamAlarmClass,
	}
	STATUS	current
	DESCRIPTION
		"Castools of virtual machine is abnormal.
		This might be caused by 1. Castools is not installed, 2. Castools is not running.
	    Fixes: 1. Install and run Castools in virtual machine."
	::= { h3cCasAlarmTrapPrefix 175 }

h3cCasAlarmSharedFilesystemFenceUmounted NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamCvkName,
		h3cCasAlarmParamCvkIpAddress,
		h3cCasAlarmParamSharedFilesystemName,
		h3cCasAlarmParamSharedFilesystemDisplayName,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The shared filesystem of the CVK host is fence umounted.
		 This might be caused by 1. storage devices failure, or 2. the physical link to the storage
		 devices is unstable."
	::= { h3cCasAlarmTrapPrefix 163 }

h3cCasAlarmVmSpectralVituralMachineRunning NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamVmDisplayName,
		h3cCasAlarmParamVmIpAddress,
		h3cCasAlarmParamVmIpv6Address,
		h3cCasAlarmParamVmName,
		h3cCasAlarmParamVmUuid,
		h3cCasAlarmParamAlarmClass
	}
	STATUS	current
	DESCRIPTION
		"The running virtual machine is not supposed to be running.
		 Possible causes: 1. MAC address confliction with other VMs, 2. the qemu process of the VM
		 still exists."
	::= { h3cCasAlarmTrapPrefix 164 }

h3cCasAlarmTomcatCpuUsage NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamResourceUsageThreshold,
		h3cCasAlarmParamResourceUsage
	}
	STATUS	current
	DESCRIPTION
		"Possible causes: 1. CVM has a large number of connections. 2. Many tasks are running on CVM."
	::= { h3cCasAlarmTrapPrefix 180 }

h3cCasAlarmTomcatMemoryUsage NOTIFICATION-TYPE
	OBJECTS {
		h3cCasAlarmParamAgentTime,
		h3cCasAlarmParamAlarmClass,
		h3cCasAlarmParamResourceUsageThreshold,
		h3cCasAlarmParamResourceUsage
	}
	STATUS	current
	DESCRIPTION
