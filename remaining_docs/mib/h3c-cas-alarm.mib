H3C-CAS-ALARM-MIB DEFINITIONS ::= BEGIN

IMPORTS
	hh3cNM											FROM HH3C-OID-MIB
	Unsigned32, OBJECT-TYPE, MODULE-IDENTITY,
	NOTIFICATION-TYPE								FROM SNMPv2-SMI
	DisplayString, DateAndTime						FROM SNMPv2-TC
	OBJECT-GROUP, NOTIFICATION-GROUP				FROM SNMPv2-CONF;

h3cCas MODULE-IDENTITY
	LAST-UPDATED "201803070735Z"
	ORGANIZATION
		"Hangzhou H3C Technologies Co., Ltd."
	CONTACT-INFO
		"Platform Team H3C Technologies Co., Ltd.
		Hai-Dian District Beijing P.R. China
		http://www.h3c.com
		Zip: 100085"
	DESCRIPTION
		"This MIB file defines alarm trap messages used in H3C
		 CAS product. An alarm is triggered when there is an error
		 or some threshold is reached among clusters, hosts or virtual
		 machines."
	REVISION "201803070735Z"
	DESCRIPTION
		"Add two new parameters and five new alarms. Add parameter
		 IPv6Address to all the vm type alarms."
	REVISION "201711011517Z"
	DESCRIPTION
		"Initial version of the MIB."
	::= { hh3cNM 2 }

h3cCasAlarm OBJECT IDENTIFIER ::= { h3cCas 26 }
h3cCasAlarmParams OBJECT IDENTIFIER ::= { h3cCasAlarm 1 }
h3cCasAlarmParamCvkName OBJECT-TYPE
	SYNTAX	DisplayString
	MAX-ACCESS	accessible-for-notify
	STATUS	current
	DESCRIPTION
		"The hostname of CVK."
	::= { h3cCasAlarmParams 1 }

h3cCasAlarmParamCvkIpAddress OBJECT-TYPE
	SYNTAX	DisplayString
	MAX-ACCESS	accessible-for-notify
	STATUS	current
	DESCRIPTION
		"The Internet protocol v4 address of CVK."
	::= { h3cCasAlarmParams 2 }

h3cCasAlarmParamAlarmClass OBJECT-TYPE
	SYNTAX	INTEGER {
				all(0),
				critical(1),
				major(2),
				minor(3),
				info(4)
			}
	MAX-ACCESS	accessible-for-notify
	STATUS	current
	DESCRIPTION
		"The severity class of an alarm. When appearing in recovery alarms, the class indicates the alarms at the same class
		 and above(severer), if there are any, classes are recovered. Specially, the alarm class all(0), which is only used
		 in recovery alarms, indicates the recovery of all the alarms arised before."
	::= { h3cCasAlarmParams 3 }

