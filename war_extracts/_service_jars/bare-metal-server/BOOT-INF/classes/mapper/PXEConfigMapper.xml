<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.h3c.h3cloud.bare.metal.mapper.PXEConfigMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="pxeConfigMap" type="com.h3c.h3cloud.bare.metal.model.PXEConfig">
        <id column="ID" property="id" />
        <result column="START_IP" property="startIp" />
        <result column="END_IP" property="endIp" />
        <result column="MASK" property="mask" />
        <result column="GATEWAY" property="gateway" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="PXE_Column_List">
        ID AS id, START_IP AS startIp, END_IP AS endIp, MASK AS mask, GATEWAY AS gateway
    </sql>

</mapper>