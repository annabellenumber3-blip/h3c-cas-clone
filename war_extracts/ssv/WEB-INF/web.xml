<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://java.sun.com/xml/ns/javaee" xmlns:web="http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd"
	xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd"
	id="WebApp_ID" version="2.5">
	<display-name>ssv</display-name>
	<context-param>
		<param-name>contextConfigLocation</param-name>
		<param-value>classpath:/com/virtual/ssv/config/beans-*.xml</param-value>
	</context-param>
	<listener>
		<listener-class>org.springframework.web.context.ContextLoaderListener</listener-class>
	</listener>
	<listener>
		<listener-class>org.springframework.web.context.request.RequestContextListener</listener-class>
	</listener>
	<listener>
		<listener-class>com.virtual.ssv.server.user.LogoutListener</listener-class>
	</listener>
	<filter>
		<filter-name>sessionFilter</filter-name>
		<filter-class>com.virtual.ssv.server.SessionFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>sessionFilter</filter-name>
		<url-pattern>/servlet/*</url-pattern>
	</filter-mapping>
	

	<servlet>
		<servlet-name>vmList</servlet-name>
		<servlet-class>com.virtual.ssv.server.virtualhost.VmListServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>vmList</servlet-name>
		<url-pattern>/servlet/vmList</url-pattern>
	</servlet-mapping>
	<servlet>
		<servlet-name>firewallServlet</servlet-name>
		<servlet-class>com.virtual.ssv.server.firewall.FirewallServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>firewallServlet</servlet-name>
		<url-pattern>/servlet/firewallServlet</url-pattern>
	</servlet-mapping>
	<servlet>
		<servlet-name>loginServlet</servlet-name>
		<servlet-class>com.virtual.ssv.server.user.LoginServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>loginServlet</servlet-name>
		<url-pattern>/login</url-pattern>
	</servlet-mapping>
	<welcome-file-list>
		<welcome-file>homeServlet</welcome-file>
	</welcome-file-list>
	<servlet>
		<description></description>
		<display-name>HomeServlet</display-name>
		<servlet-name>homeServlet</servlet-name>
		<servlet-class>com.virtual.ssv.server.home.HomeServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>homeServlet</servlet-name>
		<url-pattern>/homeServlet</url-pattern>
	</servlet-mapping>
	<servlet>
		<display-name>vmWorkFlowServlet</display-name>
		<servlet-name>workFlowServlet</servlet-name>
		<servlet-class>com.virtual.ssv.server.vmworkflow.VmWorkFlowServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>workFlowServlet</servlet-name>
		<url-pattern>/servlet/workFlowServlet</url-pattern>
	</servlet-mapping>
	<servlet>
		<display-name>workflow</display-name>
		<servlet-name>workflow</servlet-name>
		<servlet-class>com.virtual.ssv.server.workflow.WorkflowServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>workflow</servlet-name>
		<url-pattern>/servlet/workflow</url-pattern>
	</servlet-mapping>
	<servlet>
		<description>FileUploadServlet</description>
		<display-name>FileUploadServlet</display-name>
		<servlet-name>FileUploadServlet</servlet-name>
		<servlet-class>com.virtual.ssv.server.upload.FileUploadServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>FileUploadServlet</servlet-name>
		<url-pattern>/servlet/uploadServlet</url-pattern>
	</servlet-mapping>
	<servlet>
		<display-name>BackupServlet</display-name>
		<servlet-name>BackupServlet</servlet-name>
		<servlet-class>com.virtual.ssv.server.backup.BackupServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>BackupServlet</servlet-name>
		<url-pattern>/servlet/backupServlet</url-pattern>
	</servlet-mapping>
	<servlet>
		<display-name>applyDiskServlet</display-name>
		<servlet-name>applyDiskServlet</servlet-name>
		<servlet-class>com.virtual.ssv.server.applydisk.ApplyDiskServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>applyDiskServlet</servlet-name>
		<url-pattern>/servlet/applyDiskServlet</url-pattern>
	</servlet-mapping>
	<servlet>
		<display-name>cloudMessageServlet</display-name>
		<servlet-name>cloudMessageServlet</servlet-name>
		<servlet-class>com.virtual.ssv.server.cloudmessage.CloudMessageServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>cloudMessageServlet</servlet-name>
		<url-pattern>/servlet/cloudMessageServlet</url-pattern>
	</servlet-mapping>
	<servlet>
		<display-name>workOrderServlet</display-name>
		<servlet-name>workOrderServlet</servlet-name>
		<servlet-class>com.virtual.ssv.server.workorder.WorkOrderServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>workOrderServlet</servlet-name>
		<url-pattern>/servlet/workOrderServlet</url-pattern>
	</servlet-mapping>
	<servlet>
		<display-name>AlarmServlet</display-name>
		<servlet-name>AlarmServlet</servlet-name>
		<servlet-class>com.virtual.ssv.server.alarm.AlarmServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>AlarmServlet</servlet-name>
		<url-pattern>/servlet/alarm</url-pattern>
	</servlet-mapping>
</web-app>