      {"name": "springSecurityFilterChain", "pattern": "/*"},
      {"name": "CharacterEncodingFilter", "pattern": "/*"},
      {"name": "CasFilter", "class": "com.virtual.plat.security.casFilter", "pattern": "/*"}
