    "servlets": [
      {"name": "Jersey Spring Web Application", "pattern": "/casrs/*", "type": "REST"},
      {"name": "dispatcher", "pattern": "/", "type": "SpringMVC"},
      {"name": "entry", "class": "com.virtual.plat.server.servlet.CheckEntryServlet", "pattern": "/checkEntryServlet"}
